      "queryParams": [
        {
          "name": "pageNumber",
          "type": "integer",
          "default": 1
        },
        {
          "name": "pageSize",
          "type": "integer",
          "default": 20
        },
        {
          "name": "status",
          "type": "string | null",
          "enum": ["Pending", "Running", "Completed", "Failed"],
          "required": false,
          "default": null,
          "description": "Filter theo status. null = tất cả."
        }
      ],
      "responses": {
        "200": {
          "schema": "$ref: #/schemas/PagedTestRunModel"
        }
      }
    },
    {
      "id": "EP-4",
      "name": "GetTestRun",
      "method": "GET",
      "path": "/api/test-suites/{suiteId}/test-runs/{runId}",
      "auth": true,
      "permission": "GetTestRuns",
