            "STATUS_CODE_MISMATCH",
            "RESPONSE_SCHEMA_MISMATCH",
            "HEADER_CHECK_FAILED",
            "BODY_CONTAINS_CHECK_FAILED",
            "BODY_NOT_CONTAINS_CHECK_FAILED",
            "JSON_PATH_CHECK_FAILED",
            "RESPONSE_TIME_EXCEEDED",
            "DEPENDENCY_FAILED",
            "UNRESOLVED_VARIABLE",
            "PRE_EXECUTION_VALIDATION_FAILED"
          ]
        },
        "message": { "type": "string" },
        "target": { "type": "string | null", "description": "Field/path gây ra failure." },
        "expected": { "type": "string | null" },
        "actual": { "type": "string | null" }
      }
    },
    "ValidationWarningModel": {
      "properties": {
        "code": {
          "type": "string",
          "knownValues": [
            "NO_EXPECTATION_DEFINED",
            "ALL_CHECKS_SKIPPED",
            "SCHEMA_NOT_FOUND",
            "PARTIAL_SCHEMA_MATCH"
          ]
        },
        "message": { "type": "string" },
        "target": { "type": "string | null" }
      }
    },
    "PagedTestRunModel": {
      "properties": {
        "items": { "type": "TestRunModel[]" },
        "totalCount": { "type": "integer" },
        "pageNumber": { "type": "integer" },
        "pageSize": { "type": "integer" }
      }
    }
  },
  "feRenderingGuide": {
    "attemptTree": {
      "description": "Cách render attempt tree từ response",
      "algorithm": [
        "1. Lấy tất cả attemptIds trong attempts[]",
        "2. Root nodes = attempts có parentAttemptId === null",
        "3. Với mỗi node, lấy children từ attemptChildrenMap[attemptId] hoặc filter attempts có parentAttemptId = node.executionAttemptId",
        "4. Render theo attemptNumber tăng dần trong cùng testCaseId",
        "5. Group theo testCaseId để hiển thị per-case timeline"
      ],
      "pseudocode": "const roots = attempts.filter(a => !a.parentAttemptId);\nconst getChildren = (id) => (attemptChildrenMap[id] || []).map(childId => attempts.find(a => a.executionAttemptId === childId));\n// Render tree DFS từ roots"
    },
    "caseSummaryTable": {
      "description": "Cách hiển thị bảng tóm tắt cases",
      "notes": [
        "Dùng cases[] (không phải attempts[]) cho summary table — mỗi row = 1 testCaseId",
        "cases[].executionAttempt cho biết đây là kết quả của attempt thứ mấy",
        "Nếu executionAttempt > 1, hiện badge 'Retried' hoặc 'Replayed' cạnh status",
        "Nếu status=Skipped, hiện skippedBecauseDependencyIds với tên của dependency case"
      ]
    },
    "retryBadgeLogic": {
      "Passed, executionAttempt=1": "✅ Passed",
      "Passed, executionAttempt>1": "✅ Passed (Retried)",
      "Failed, executionAttempt=1": "❌ Failed",
      "Failed, executionAttempt>1": "❌ Failed (after N retries)",
      "Skipped": "⏭ Skipped — depends on [X, Y]",
      "isReplay=true": "🔁 Replayed"
    }
  }
}
