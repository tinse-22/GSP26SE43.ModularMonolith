{
  "module": "ClassifiedAds.Modules.TestExecution",
  "controller": "TestRunsController",
  "baseRoute": "/api/test-suites/{suiteId:guid}/test-runs",
  "generatedAt": "2026-04-25",
  "schemaVersion": "4.1.0",
  "changesSinceLastVersion": {
    "apiContractChanged": false,
    "note": "Request/response JSON shape UNCHANGED. Only internal engine behavior changed. FE does NOT need to rewire API calls. However FE must handle 4 behavioral differences described below.",
    "behavioralChanges": [
      {
        "id": "BC-1",
        "field": "response.Cases",
        "change": "Each testCaseId now appears EXACTLY ONCE — the final-attempt outcome. Previously duplicates could appear when MaxRetryAttempts >= 1. FE should no longer de-duplicate Cases by testCaseId.",
        "impact": "LOW — if FE was already rendering Cases as a flat list, this is a fix not a break."
      },
      {
        "id": "BC-2",
        "field": "response.Attempts",
        "change": "When MaxRetryAttempts > 1 the Attempts array now contains the FULL retry chain (attempt1 → attempt2 → attempt3). Previously only one retry was generated regardless of MaxRetryAttempts.",
        "impact": "MEDIUM — if FE renders the attempt tree it now receives a deeper tree. No structural change; just more nodes."
      },
      {
        "id": "BC-3",
        "field": "response.Attempts (replay)",
        "change": "Cascading replay is now multi-pass. If dependency A is recovered, case B (which depended on A) is replayed. If B then passes and case C depends on B, C is also replayed in the same run. Previously only one replay sweep was done.",
        "impact": "MEDIUM — FE may see more replay attempts in the tree. RetryReason will be 'Replayed skipped case after dependency recovery'."
      },
      {
        "id": "BC-4",
        "field": "request.retryPolicy.maxRetryAttempts",
        "change": "Values > 1 now work correctly. Previously only 1 retry happened regardless of value. FE can now safely expose a numeric input for this field.",
        "impact": "LOW — fix, not a break."
      }
    ]
  },
  "endpoints": [
    {
      "id": "EP-1",
      "name": "StartTestRun",
      "method": "POST",
      "path": "/api/test-suites/{suiteId}/test-runs",
      "auth": true,
      "permission": "StartTestRun",
      "description": "Tạo và chạy một test run mới. Đây là long-running operation — response trả về SAU KHI toàn bộ run hoàn thành.",
      "routeParams": [
        {
          "name": "suiteId",
          "type": "uuid",
          "required": true,
          "description": "ID của test suite cần chạy"
        }
      ],
      "requestBody": {
        "contentType": "application/json",
        "schema": {
          "environmentId": {
            "type": "uuid | null",
            "required": false,
            "default": null,
            "description": "ID của execution environment. Nếu null, dùng environment mặc định của project."
          },
          "selectedTestCaseIds": {
            "type": "uuid[]",
            "required": false,
            "default": null,
            "description": "Danh sách testCaseId muốn chạy. Nếu null hoặc rỗng thì chạy toàn bộ suite."
          },
          "strictValidation": {
            "type": "boolean",
            "required": false,
            "default": false,
            "description": "Bật strict mode: schema mismatch sẽ fail thay vì warning."
          },
          "retryPolicy": {
            "type": "object | null",
            "required": false,
            "default": null,
            "description": "Nếu có, ưu tiên hơn các scalar field bên dưới (maxRetryAttempts, retryFailedDependencies, rerunSkippedCases).",
            "schema": {
              "maxRetryAttempts": {
                "type": "integer",
                "required": false,
                "default": 0,
                "min": 0,
                "max": 3,
                "description": "Số lần retry tối đa cho mỗi test case thất bại. 0 = không retry. Tối đa 3. Giá trị lớn hơn sẽ bị clamp xuống 3 phía server."
              },
              "retryFailedDependencies": {
                "type": "boolean",
                "required": false,
                "default": true,
                "description": "Có retry những test case thất bại do dependency fail không."
              },
              "rerunSkippedCases": {
                "type": "boolean",
                "required": false,
                "default": true,
                "description": "Sau khi dependency được retry và pass, có replay lại những test case đã bị skip không."
              }
            }
          },
          "maxRetryAttempts": {
            "type": "integer",
            "required": false,
            "default": 0,
            "description": "Scalar fallback — chỉ dùng nếu retryPolicy là null. Tối đa 3."
          },
          "retryFailedDependencies": {
            "type": "boolean",
            "required": false,
            "default": true,
            "description": "Scalar fallback — chỉ dùng nếu retryPolicy là null."
          },
          "rerunSkippedCases": {
            "type": "boolean",
            "required": false,
            "default": true,
            "description": "Scalar fallback — chỉ dùng nếu retryPolicy là null."
          }
        },
        "examples": {
          "minimal": {
            "environmentId": null,
            "selectedTestCaseIds": null,
            "strictValidation": false,
            "retryPolicy": null
          },
          "withRetry": {
            "environmentId": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
            "selectedTestCaseIds": [
              "11111111-1111-1111-1111-111111111111",
              "22222222-2222-2222-2222-222222222222"
            ],
            "strictValidation": false,
            "retryPolicy": {
              "maxRetryAttempts": 2,
              "retryFailedDependencies": true,
              "rerunSkippedCases": true
            }
          },
          "noRetryNoReplay": {
            "environmentId": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
            "selectedTestCaseIds": null,
            "strictValidation": true,
            "retryPolicy": {
              "maxRetryAttempts": 0,
              "retryFailedDependencies": false,
              "rerunSkippedCases": false
            }
          }
        }
      },
      "responses": {
        "201": {
          "description": "Run hoàn thành. Body = TestRunResultModel.",
          "schema": "$ref: #/schemas/TestRunResultModel"
        },
        "400": {
          "description": "Validation error — suiteId thiếu, testCaseIds không hợp lệ, hoặc suite chưa Ready."
        },
        "404": {
          "description": "Suite hoặc environment không tìm thấy."
        },
        "409": {
          "description": "Đã đạt giới hạn concurrent runs hoặc monthly quota."
        }
      }
    },
    {
      "id": "EP-2",
      "name": "GetTestRunResults",
      "method": "GET",
      "path": "/api/test-suites/{suiteId}/test-runs/{runId}/results",
      "auth": true,
      "permission": "GetTestRuns",
      "description": "Lấy kết quả đầy đủ của một run đã hoàn thành, bao gồm attempt tree. Đây là endpoint FE dùng để hiển thị detail view.",
      "routeParams": [
        {
          "name": "suiteId",
          "type": "uuid",
          "required": true
        },
        {
          "name": "runId",
          "type": "uuid",
          "required": true
        }
      ],
      "responses": {
        "200": {
          "description": "Kết quả đầy đủ.",
          "schema": "$ref: #/schemas/TestRunResultModel"
        },
        "404": {
          "description": "Run không tìm thấy hoặc không thuộc suite này."
        },
        "409": {
          "description": "Run vẫn đang chạy (status = Running)."
        }
      }
    },
    {
      "id": "EP-3",
      "name": "GetTestRuns",
      "method": "GET",
      "path": "/api/test-suites/{suiteId}/test-runs",
      "auth": true,
      "permission": "GetTestRuns",
