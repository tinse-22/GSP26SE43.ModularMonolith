    "POST /api/projects -> lay projectId",
    "POST /api/projects/{projectId}/specifications/upload -> lay apiSpecId/specificationId",
    "POST /api/projects/{projectId}/test-suites -> lay suiteId va rowVersion",
    "POST /api/projects/{projectId}/srs-documents voi testSuiteId -> lay srsDocumentId va attach vao suite",
    "POST /api/projects/{projectId}/srs-documents/{srsDocumentId}/analyze -> lay jobId",
    "GET /api/projects/{projectId}/srs-documents/{srsDocumentId}/analysis-jobs/{jobId} -> poll den Completed/Failed",
    "GET/PATCH requirements va clarifications",
    "POST /api/test-suites/{suiteId}/order-proposals -> PUT reorder neu can -> POST approve",
    "POST /api/test-suites/{suiteId}/llm-suggestions/generate",
    "GET /api/projects/{projectId}/test-suites/{suiteId}/traceability"
