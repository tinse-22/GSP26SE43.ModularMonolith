# ╔══════════════════════════════════════════════════════════════════════╗
# ║  Docker-specific environment variables                              ║
# ║                                                                      ║
# ║  Usage: cp .env.docker.example .env.docker                          ║
# ║  Then:  docker compose --env-file .env.docker up                     ║
# ║                                                                      ║
# ║  Hosts use Docker service names (db, rabbitmq, redis, mailhog)       ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ===========================================
# Database
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=ClassifiedAds
POSTGRES_HOST_PORT=55432

# Docker host = service name "db"
ConnectionStrings__Default=Host=db;Port=5432;Database=ClassifiedAds;Username=postgres;Password=your_secure_password_here

# ===========================================
# JWT Authentication
# ===========================================
Modules__Identity__Jwt__SecretKey=your-jwt-secret-key-must-be-at-least-32-characters-long!
Modules__Identity__Jwt__Issuer=ClassifiedAds
Modules__Identity__Jwt__Audience=ClassifiedAds.WebAPI

# ===========================================
# Storage
# ===========================================
Modules__Storage__Provider=Local
Modules__Storage__MasterEncryptionKey=your_encryption_key_here
Modules__Storage__Local__Path=/app/storage

# -- Firebase (uncomment to use) --
# Modules__Storage__Provider=Firebase
# Modules__Storage__Firebase__Bucket=your-project.appspot.com
# Modules__Storage__Firebase__CredentialFilePath=/app/secrets/firebase-key.json

# ===========================================
# Email (Docker mailhog)
# ===========================================
Modules__Notification__Email__Provider=SmtpClient
Modules__Notification__Email__SmtpClient__Host=mailhog
Modules__Notification__Email__SmtpClient__Port=1025
Modules__Notification__Email__SmtpClient__EnableSsl=false

# ===========================================
# Email Queue (Background Worker)
# ===========================================
Modules__Notification__EmailQueue__ChannelCapacity=64
Modules__Notification__EmailQueue__MaxDegreeOfParallelism=3
Modules__Notification__EmailQueue__MaxRetryAttempts=5
Modules__Notification__EmailQueue__SendTimeoutSeconds=30

# ===========================================
# SMS
# ===========================================
Modules__Notification__Sms__Provider=Fake

# ===========================================
# Messaging (Docker RabbitMQ)
# ===========================================
Messaging__Provider=RabbitMQ
Messaging__RabbitMQ__HostName=rabbitmq
Messaging__RabbitMQ__UserName=guest
Messaging__RabbitMQ__Password=guest

# ===========================================
# Caching (Redis) - single source of truth
# ===========================================
# External Redis/Upstash:
# REDIS_URL=rediss://default:password@your-upstash-host:6379
# Local Docker Redis fallback:
# REDIS_URL=redis://redis:6379
REDIS_URL=redis://redis:6379
# Enable this only when using the local docker redis fallback above.
COMPOSE_PROFILES=local-redis
Caching__Distributed__Redis__InstanceName=ClassifiedAds_
