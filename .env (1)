# ===========================================
# Local Development Environment Variables
# ===========================================
# Loaded automatically by dotenv.net when running: dotnet run
# ===========================================

# ===========================================
# Database Configuration
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ClassifiedAds

# ===========================================
# Application Environment
# ===========================================
ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development

# ===========================================
# Connection Strings (Local: 127.0.0.1)
# ===========================================
ConnectionStrings__Default=Host=127.0.0.1;Port=5432;Database=ClassifiedAds;Username=postgres;Password=postgres

# ===========================================
# Storage Configuration
# ===========================================
Modules__Storage__Provider=Local
Modules__Storage__Local__Path=C:\Data\files

# ===========================================
# JWT Authentication
# ===========================================
Modules__Identity__Jwt__SecretKey=ClassifiedAds-JWT-Secret-Key-Must-Be-At-Least-32-Characters-Long-2026!
Modules__Identity__Jwt__Issuer=ClassifiedAds
Modules__Identity__Jwt__Audience=ClassifiedAds.WebAPI

# ===========================================
# Messaging Configuration (RabbitMQ)
# ===========================================
Messaging__Provider=RabbitMQ
Messaging__RabbitMQ__HostName=localhost

# ===========================================
# Email Notification (Gmail SMTP)
# ===========================================
Modules__Notification__Email__Provider=SmtpClient
Modules__Notification__Email__SmtpClient__Host=smtp.gmail.com
Modules__Notification__Email__SmtpClient__Port=587
Modules__Notification__Email__SmtpClient__UserName=tinvtse@gmail.com
Modules__Notification__Email__SmtpClient__Password=yowc jhpu pqbd bdao
Modules__Notification__Email__SmtpClient__EnableSsl=true

# ===========================================
# Caching (use InMemory for local dev without Redis)
# ===========================================
Caching__Distributed__Provider=InMemory