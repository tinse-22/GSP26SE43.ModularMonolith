        "LlmSuggestionTimeoutSeconds": 90,
       
          "BeBaseUrl": "https://paris-collarless-unimplicitly.ngrok-free.dev",
        "CallbackApiKey": "n8n-callback-secret-2026",
        "UseDotnetIntegrationWorkflowForGeneration": true,
        "GenerationModel": "gpt-4.1-mini",
