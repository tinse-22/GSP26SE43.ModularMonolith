{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "System": "Warning",
      "Microsoft": "Warning"
    },
    "OpenTelemetry": {
      "IsEnabled": true,
      "ServiceName": "ClassifiedAds.WebAPI",
      "Otlp": {
        "IsEnabled": true,
        "Endpoint": "https://localhost:21052"
      }
    }
  },
  "Monitoring": {
    "OpenTelemetry": {
      "IsEnabled": true,
      "ServiceName": "ClassifiedAds.WebAPI",
      "Otlp": {
        "IsEnabled": true,
        "Endpoint": "https://localhost:21052"
      }
    }
  },
  "Caching": {
    "Distributed": {
      "Provider": "InMemory"
    }
  },
  "Modules": {
    "TestReporting": {
      "ReportGeneration": {
        "DefaultHistoryLimit": 5,
        "MaxHistoryLimit": 20,
        "MaxResponseBodyPreviewChars": 4000,
        "ReportRetentionHours": 168
      }
    },
    "TestGeneration": {
      "N8nIntegration": {
        "BaseUrl": "https://tinem224.app.n8n.cloud/webhook/",
        "TimeoutSeconds": 60,
        "BeBaseUrl": "http://localhost:5099",
        "CallbackApiKey": "n8n-callback-secret-2026",
        "UseDotnetIntegrationWorkflowForGeneration": true,
        "Webhooks": {
          "generate-test-cases-unified": "generate-test-cases-unified",
          "generate-llm-suggestions": "generate-llm-suggestions",
          "DotnetIntegration": "dotnet-integration",
          "generate-happy-path": "generate-happy-path",
          "generate-boundary-negative-scenarios": "generate-boundary-negative-scenarios"
        }
      }
    },
    "LlmAssistant": {
      "FailureExplanation": {
        "Provider": "N8n",
        "Model": "deepseek-chat",
        "TimeoutSeconds": 60,
        "CacheTtlHours": 24,
        "BaseUrl": "https://tinem224.app.n8n.cloud/webhook/",
        "ApiKey": "my-super-secret-key-2026",
        "WebhookPath": "explain-failure"
      }
    }
  }
}
