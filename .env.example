# ╔══════════════════════════════════════════════════════════════════════╗
# ║  ClassifiedAds.ModularMonolith - Environment Variables              ║
# ║                                                                      ║
# ║  Usage:                                                              ║
# ║    Local dev (dotnet run):  cp .env.example .env                     ║
# ║    Docker (compose):        cp .env.example .env.docker              ║
# ║                                                                      ║
# ║  NEVER commit .env or .env.docker to git!                            ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ===========================================
# Application Environment
# ===========================================
ASPNETCORE_ENVIRONMENT=Development

# ===========================================
# Database
# ===========================================
# Optional local postgres values for compose profile "local-db"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=ClassifiedAds
POSTGRES_HOST_PORT=55432

# Full project default: external Supabase/PostgreSQL
# Prefer the direct database host on port 5432 when your network supports IPv6.
# If your environment is IPv4-only, switch back to the Supavisor session pooler.
# Important: Supabase reserves schema "storage" for its own product. The current
# ClassifiedAds Storage module also uses schema "storage", so storage migrations will
# conflict on Supabase until that module schema is renamed in code.
# If your password contains '@', encode it as '%40' when using URI style; plain connection
# string format below can keep '@' directly.
ConnectionStrings__Default=Host=db.yourprojectref.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=your_password;SSL Mode=Require;Trust Server Certificate=true
CheckDependency__Host=db.yourprojectref.supabase.co:5432

# ===========================================
# JWT Authentication
# ===========================================
Modules__Identity__Jwt__SecretKey=your-jwt-secret-key-must-be-at-least-32-characters-long!
Modules__Identity__Jwt__Issuer=ClassifiedAds
Modules__Identity__Jwt__Audience=ClassifiedAds.WebAPI
Modules__Identity__Jwt__AccessTokenExpirationMinutes=60
Modules__Identity__Jwt__RefreshTokenExpirationDays=7

# ===========================================
# PayOS (Subscription module)
# ===========================================
Modules__Subscription__PayOS__ClientId=your_payos_client_id
Modules__Subscription__PayOS__ApiKey=your_payos_api_key
Modules__Subscription__PayOS__ChecksumKey=your_payos_checksum_key
# Optional runtime overrides
# Modules__Subscription__PayOS__BaseUrl=https://api-merchant.payos.vn
# Modules__Subscription__PayOS__ReturnUrl=https://your-webapi-host/api/payments/payos/return
# Modules__Subscription__PayOS__WebhookUrl=https://your-webapi-host/api/payments/payos/webhook
# Modules__Subscription__PayOS__CancelUrl=https://your-frontend-host/payment/cancel
# Modules__Subscription__PayOS__FrontendBaseUrl=https://your-frontend-host

# ===========================================
# Storage
# ===========================================
# Providers: Local | Azure | Amazon | Firebase | Fake
Modules__Storage__Provider=Local
Modules__Storage__MasterEncryptionKey=your_encryption_key_here

# -- Local --
Modules__Storage__Local__Path=C:\Data\files

# -- Azure Blob --
# Modules__Storage__Azure__ConnectionString=DefaultEndpointsProtocol=https;AccountName=xxx;AccountKey=xxx
# Modules__Storage__Azure__Container=classifiedads

# -- Amazon S3 --
# Modules__Storage__Amazon__AccessKeyID=your_aws_key
# Modules__Storage__Amazon__SecretAccessKey=your_aws_secret
# Modules__Storage__Amazon__BucketName=classifiedads
# Modules__Storage__Amazon__RegionEndpoint=ap-southeast-1

# -- Firebase (Google Cloud Storage) --
# Modules__Storage__Firebase__CredentialFilePath=path/to/serviceAccountKey.json
# Modules__Storage__Firebase__Bucket=your-project.appspot.com
# Modules__Storage__Firebase__Path=

# ===========================================
# Email Notification
# ===========================================
# Providers: Fake | SmtpClient | SendGrid
Modules__Notification__Email__Provider=Fake
# Modules__Notification__Email__SmtpClient__Host=smtp.gmail.com
# Modules__Notification__Email__SmtpClient__Port=587
# Modules__Notification__Email__SmtpClient__UserName=your_email
# Modules__Notification__Email__SmtpClient__Password=your_app_password
# Modules__Notification__Email__SmtpClient__EnableSsl=true
# Modules__Notification__Email__SendGrid__ApiKey=your_sendgrid_key

# ===========================================
# Email Queue (Background Worker)
# ===========================================
# Modules__Notification__EmailQueue__ChannelCapacity=64
# Modules__Notification__EmailQueue__MaxDegreeOfParallelism=3
# Modules__Notification__EmailQueue__MaxRetryAttempts=5
# Modules__Notification__EmailQueue__BaseDelaySeconds=5
# Modules__Notification__EmailQueue__MaxDelaySeconds=120
# Modules__Notification__EmailQueue__SendTimeoutSeconds=30
# Modules__Notification__EmailQueue__CircuitBreakerFailureThreshold=5
# Modules__Notification__EmailQueue__CircuitBreakerDurationSeconds=60
# Modules__Notification__EmailQueue__DbSweepIntervalSeconds=30

# ===========================================
# SMS Notification
# ===========================================
# Providers: Fake | Twilio | Azure
Modules__Notification__Sms__Provider=Fake
# Modules__Notification__Sms__Twilio__AccountSId=your_twilio_sid
# Modules__Notification__Sms__Twilio__AuthToken=your_twilio_token
# Modules__Notification__Sms__Twilio__FromNumber=+1234567890

# ===========================================
# Caching (Redis) - single source of truth
# ===========================================
# Local dotnet run: redis://127.0.0.1:6379
# Hosted Redis/Upstash: rediss://default:password@your-upstash-host:6379
REDIS_URL=redis://127.0.0.1:6379
Caching__Distributed__Redis__InstanceName=ClassifiedAds_

# ===========================================
# Messaging (RabbitMQ)
# ===========================================
# Standalone docker/local mode defaults to guest/guest.
# AppHost mode injects host/port/user/password automatically and overrides these at runtime.
Messaging__Provider=RabbitMQ
Messaging__RabbitMQ__HostName=localhost
Messaging__RabbitMQ__UserName=guest
Messaging__RabbitMQ__Password=guest

# ===========================================
# Certificates
# ===========================================
# Authentication__Jwt__TokenDecryptionCertificate__Password=password1234
# Modules__Configuration__Certificates__SettingsEncryption__Password=password1234

# ===========================================
# n8n Integration (TestGeneration module)
# ===========================================
# Modules__TestGeneration__N8nIntegration__BaseUrl=https://your-n8n-host/webhook/
# Modules__TestGeneration__N8nIntegration__ApiKey=your_n8n_api_key_here
# Modules__TestGeneration__N8nIntegration__BeBaseUrl=https://your-public-webapi-host
# Modules__TestGeneration__N8nIntegration__CallbackApiKey=change-me
# Modules__TestGeneration__N8nIntegration__UseDotnetIntegrationWorkflowForGeneration=true
# Modules__TestGeneration__N8nIntegration__Webhooks__generate-test-cases-unified=generate-test-cases-unified
# Modules__TestGeneration__N8nIntegration__Webhooks__generate-llm-suggestions=generate-llm-suggestions
# Modules__TestGeneration__N8nIntegration__Webhooks__analyze-srs=analyze-srs
# Modules__TestGeneration__N8nIntegration__Webhooks__refine-srs-requirements=refine-srs-requirements

# ===========================================
# n8n Failure Explanation (LlmAssistant module / FE-09)
# ===========================================
# Modules__LlmAssistant__FailureExplanation__Provider=N8n
# Modules__LlmAssistant__FailureExplanation__Model=gpt-4.1-mini
# Modules__LlmAssistant__FailureExplanation__TimeoutSeconds=300
# Modules__LlmAssistant__FailureExplanation__CacheTtlHours=24
# Modules__LlmAssistant__FailureExplanation__BaseUrl=https://your-n8n-host/webhook/
# Modules__LlmAssistant__FailureExplanation__ApiKey=your_n8n_api_key_here
# Modules__LlmAssistant__FailureExplanation__WebhookPath=explain-failure
