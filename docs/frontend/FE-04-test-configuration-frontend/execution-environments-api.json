  "endpoints": [
    {
      "name": "ListExecutionEnvironments",
      "method": "GET",
      "path": "/api/projects/{projectId}/execution-environments",
      "pathParams": [
        "projectId: Guid"
      ],
      "query": [],
      "sorting": {
        "supportsClientProvidedSort": false,
        "serverOrder": "IsDefault desc, Name asc"
      },
      "response": {
        "status": 200,
        "body": "ExecutionEnvironmentModel[]"
      },
      "notes": [
        "Current implementation does not perform a separate project existence lookup; no matches return 200 with an empty array."
      ]
    },
    {
      "name": "GetExecutionEnvironmentDetail",
      "method": "GET",
      "path": "/api/projects/{projectId}/execution-environments/{environmentId}",
      "pathParams": [
        "projectId: Guid",
        "environmentId: Guid"
      ],
      "query": [],
      "response": {
        "status": 200,
        "body": "ExecutionEnvironmentModel"
      },
      "problemCases": [
        "404 when environmentId does not exist under the provided projectId."
      ]
    },
    {
      "name": "CreateExecutionEnvironment",
      "method": "POST",
      "path": "/api/projects/{projectId}/execution-environments",
      "pathParams": [
        "projectId: Guid"
      ],
      "query": [],
      "requestBody": "CreateExecutionEnvironmentRequest",
      "response": {
        "status": 201,
        "body": "ExecutionEnvironmentModel",
        "headers": [
          "Location"
        ]
      },
      "problemCases": [
        "400 ValidationProblemDetails when required body fields are missing.",
        "400 ProblemDetails for invalid baseUrl, empty header key, empty variable key, invalid authConfig payload, or missing auth secrets required by the selected authType.",
        "409 ProblemDetails with reasonCode=DEFAULT_ENVIRONMENT_CONFLICT when concurrent default switching conflicts."
      ]
    },
    {
      "name": "UpdateExecutionEnvironment",
      "method": "PUT",
      "path": "/api/projects/{projectId}/execution-environments/{environmentId}",
      "pathParams": [
        "projectId: Guid",
        "environmentId: Guid"
      ],
      "query": [],
      "requestBody": "UpdateExecutionEnvironmentRequest",
      "response": {
        "status": 200,
        "body": "ExecutionEnvironmentModel"
      },
      "problemCases": [
        "400 ValidationProblemDetails when rowVersion or other required body fields are missing.",
        "400 ProblemDetails for invalid rowVersion format, invalid baseUrl, empty header key, empty variable key, or invalid authConfig data.",
        "404 when environmentId does not exist under the provided projectId.",
        "409 ProblemDetails with reasonCode=CONCURRENCY_CONFLICT when rowVersion is stale.",
        "409 ProblemDetails with reasonCode=DEFAULT_ENVIRONMENT_CONFLICT when concurrent default switching conflicts."
      ]
    },
    {
      "name": "DeleteExecutionEnvironment",
      "method": "DELETE",
      "path": "/api/projects/{projectId}/execution-environments/{environmentId}",
      "pathParams": [
        "projectId: Guid",
        "environmentId: Guid"
      ],
      "query": [
        "rowVersion: base64 string (required)"
      ],
      "response": {
        "status": 204,
        "body": "empty"
      },
      "problemCases": [
        "400 when rowVersion query is missing or invalid.",
        "404 when environmentId does not exist under the provided projectId.",
        "409 ProblemDetails with reasonCode=CONCURRENCY_CONFLICT when rowVersion is stale."
      ],
      "notes": [
        "Current implementation allows deleting the default environment and does not auto-select a replacement."
      ]
    }
  ],
  "runtimeRules": [
    "List is sorted with default environments first, then by environment name ascending.",
    "Response authConfig is masked on list, detail, create response, and update response.",
    "Do not send masked secrets back unchanged on update unless you intentionally want to overwrite the stored secret with ******.",
    "Backend enforces at most one default environment per project, but it does not require a project to always keep one default.",
    "Setting isDefault=true uses a serializable transaction to unset other defaults in the same project.",
    "Setting isDefault=false on the current default environment is allowed and can leave the project without any default environment.",
    "Delete requires rowVersion via query string instead of request body."
  ],
