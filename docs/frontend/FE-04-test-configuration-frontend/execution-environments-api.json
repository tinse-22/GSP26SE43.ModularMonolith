      "notes": [
        "Response always masks token, password, apiKeyValue, and clientSecret as ******.",
        "BearerToken requires token.",
        "Basic requires username plus password.",
        "ApiKey requires apiKeyName plus apiKeyValue.",
        "OAuth2ClientCredentials requires tokenUrl, clientId, and clientSecret."
      ]
    },
