{
  "$schema": "frontend-api-contract",
  "version": "1.0.0",
  "documentId": "fe-10-reports-export-api",
  "validatedAgainstCodebaseOn": "2026-03-26",
  "controller": "TestReportsController",
  "baseRoute": "/api/test-suites/{suiteId}/test-runs/{runId}/reports",
  "authentication": {
    "required": true,
    "scheme": "Bearer"
  },
  "permissions": {
    "GenerateTestRunReport": "Permission:GetTestRuns",
    "GetTestRunReports": "Permission:GetTestRuns",
    "GetTestRunReport": "Permission:GetTestRuns",
    "DownloadTestRunReport": "Permission:GetTestRuns"
  },
  "prerequisiteDocs": [
    "FE-07/08 test run results: docs/frontend/FE-07-08-test-execution-validation-frontend/test-runs-api.json",
    "Backend planning package for FE-10: docs/features/FE-10-reports-export"
  ],
  "enums": {
    "ReportTypeRequestAndResponse": [
      "Summary",
      "Detailed",
      "Coverage"
    ],
    "ReportFormatRequestAndResponse": [
      "PDF",
      "CSV",
      "JSON",
      "HTML"
    ],
    "ConflictReasonCodes": [
      "RUN_RESULTS_EXPIRED",
      "REPORT_RUN_NOT_READY"
    ],
    "NotFoundMessagePrefixes": [
      "REPORT_NOT_FOUND",
      "REPORT_FILE_NOT_FOUND"
    ],
    "ValidationMessagePrefixes": [
      "REPORT_FORMAT_NOT_SUPPORTED"
    ]
  },
  "models": {
    "GenerateTestReportRequest": {
      "contentType": "application/json",
      "properties": [
        "reportType: string enum = Summary | Detailed | Coverage",
        "format: string enum = PDF | CSV | JSON | HTML",
        "recentHistoryLimit: int? optional"
      ],
      "notes": [
        "reportType va format duoc backend trim + parse case-insensitive.",
        "recentHistoryLimit omit => fallback config DefaultHistoryLimit, hien tai la 5.",
        "recentHistoryLimit runtime cho phep 1..20 theo config WebAPI hien tai."
      ]
    },
    "TestReportModel": {
      "properties": [
        "id: Guid",
        "testSuiteId: Guid",
        "testRunId: Guid",
        "reportType: string enum",
        "format: string enum",
        "downloadUrl: string relative route",
        "generatedAt: DateTimeOffset",
        "expiresAt: DateTimeOffset?",
        "coverage: CoverageMetricModel?"
      ],
      "notes": [
        "downloadUrl duoc build server-side theo mau /api/test-suites/{suiteId}/test-runs/{runId}/reports/{reportId}/download.",
        "coverage la snapshot coverage cua run, khong phu thuoc reportType dang la Summary/Detailed/Coverage."
      ]
    },
    "CoverageMetricModel": {
      "properties": [
        "testRunId: Guid",
        "totalEndpoints: int",
        "testedEndpoints: int",
        "coveragePercent: decimal",
        "byMethod: Dictionary<string, decimal>",
        "byTag: Dictionary<string, decimal>",
        "uncoveredPaths: string[]",
        "calculatedAt: DateTimeOffset"
      ],
      "notes": [
        "testedEndpoints dem endpoint co case runtime khong bi Skipped.",
        "byMethod key thuong la GET/POST/...; byTag la tag suy ra tu metadata path hoac fallback path."
      ]
    },
    "DownloadBinaryResponse": {
      "body": "binary bytes",
      "headers": [
        "Content-Type: application/pdf | text/csv; charset=utf-8 | application/json; charset=utf-8 | text/html; charset=utf-8",
        "Content-Disposition: attachment; filename=<stored file name>"
      ],
      "notes": [
        "Controller tra File(...) truc tiep, khong co JSON envelope.",
        "Ten file la ten da luu trong Storage va duoc HTML-encode truoc khi return."
      ]
    },
    "JsonReportDownloadPayload": {
      "properties": [
        "testSuiteId: Guid",
        "projectId: Guid",
        "apiSpecId: Guid?",
        "suiteName: string",
        "reportType: string enum",
        "generatedAt: DateTimeOffset",
        "fileBaseName: string",
        "run: TestRunReportRunDto",
        "coverage: CoverageMetricModel",
        "failureDistribution: Dictionary<string,int>",
        "recentRuns: TestRunHistoryItemDto[]",
        "cases: TestRunReportCaseDocumentModel[]"
      ],
      "notes": [
        "Chi xuat hien ben trong file download khi format = JSON.",
        "Summary va Coverage report van co top-level shape giong nhau, nhung Summary/Coverage co the khong co case-level details day du."
      ]
    },
    "TestRunReportRunDto": {
      "properties": [
        "testRunId: Guid",
        "runNumber: int",
        "environmentId: Guid",
        "triggeredById: Guid",
        "status: string",
        "startedAt: DateTimeOffset?",
        "completedAt: DateTimeOffset?",
        "durationMs: long",
        "totalTests: int",
        "passedCount: int",
        "failedCount: int",
        "skippedCount: int",
        "resolvedEnvironmentName: string?",
        "executedAt: DateTimeOffset"
      ]
    },
    "TestRunHistoryItemDto": {
      "properties": [
        "testRunId: Guid",
        "runNumber: int",
        "status: string",
        "completedAt: DateTimeOffset?",
        "durationMs: long",
        "passedCount: int",
        "failedCount: int",
        "skippedCount: int"
      ]
    },
    "TestRunReportCaseDocumentModel": {
      "properties": [
        "testCaseId: Guid",
        "endpointId: Guid?",
        "name: string",
        "description: string?",
        "testType: string?",
        "orderIndex: int",
        "dependencyIds: Guid[]",
        "request: ExecutionTestCaseRequestDto?",
        "expectation: ExecutionTestCaseExpectationDto?",
        "status: string?",
        "httpStatusCode: int?",
        "durationMs: long",
        "resolvedUrl: string?",
        "requestHeaders: Dictionary<string,string>",
        "responseHeaders: Dictionary<string,string>",
        "responseBodyPreview: string?",
        "failureReasons: ReportValidationFailureDto[]",
        "extractedVariables: Dictionary<string,string>",
        "skippedBecauseDependencyIds: Guid[]",
        "statusCodeMatched: bool",
        "schemaMatched: bool?",
        "headerChecksPassed: bool?",
        "bodyContainsPassed: bool?",
        "bodyNotContainsPassed: bool?",
        "jsonPathChecksPassed: bool?",
        "responseTimePassed: bool?"
      ],
      "notes": [
        "Case-level section chi duoc render day du khi reportType = Detailed.",
        "request/expectation field ben trong file JSON van giu dang chuoi JSON, khong phai object typed."
      ]
    },
    "ReportValidationFailureDto": {
      "properties": [
        "code: string",
        "message: string",
        "target: string?",
        "expected: string?",
        "actual: string?"
      ]
    },
    "ProblemDetails": {
      "contentType": "application/problem+json",
      "properties": [
        "type: string",
        "title: string",
        "status: int",
        "detail: string",
        "message: string",
        "traceId: string",
        "reasonCode: string?"
      ],
      "notes": [
        "reasonCode hien chi co voi ConflictException va mot so conflict tu infrastructure.",
        "404 report/report-file not found hien dung detail/message prefix, khong co field reasonCode rieng."
      ]
    },
    "ValidationProblemDetails": {
      "contentType": "application/problem+json",
      "properties": [
        "type: string",
        "title: string",
        "status: int",
        "instance: string",
        "traceId: string",
        "errors: Dictionary<string,string[]>"
      ]
    }
  },
  "endpoints": [
    {
      "name": "GenerateTestRunReport",
      "method": "POST",
      "path": "/api/test-suites/{suiteId}/test-runs/{runId}/reports",
      "pathParams": [
        "suiteId: Guid",
        "runId: Guid"
      ],
      "query": [],
      "requestBody": "GenerateTestReportRequest",
      "response": {
        "status": 201,
        "body": "TestReportModel",
        "headers": [
          "Location: /api/test-suites/{suiteId}/test-runs/{runId}/reports/{reportId}"
        ]
      },
      "problemCases": [
        "400 ValidationProblemDetails khi body JSON sai shape hoac ASP.NET model binding fail.",
        "400 ProblemDetails cho reportType/format rong, enum sai, recentHistoryLimit < 1 hoac > 20, non-owner access, hoac runtime khong co renderer cho format da yeu cau.",
        "404 khi suiteId khong ton tai hoac runId khong ton tai trong suite.",
        "409 ProblemDetails voi reasonCode=REPORT_RUN_NOT_READY khi run chua Completed/Failed.",
        "409 ProblemDetails voi reasonCode=RUN_RESULTS_EXPIRED khi detailed run results da het han cache."
      ],
      "notes": [
        "Current implementation la synchronous request-response; backend khong tao queue/polling job.",
        "Moi lan success se tao report moi, upload file moi, va upsert CoverageMetric cho run.",
        "Filename runtime theo mau test-run-{runNumber}-{reportTypeLower}-{formatLower}-{yyyyMMddTHHmmssZ}.{ext}.",
        "PDF/HTML luu fileCategory = Report; CSV/JSON luu fileCategory = Export, nhung FE khong nhin thay field nay."
      ]
    },
    {
      "name": "GetTestRunReports",
      "method": "GET",
      "path": "/api/test-suites/{suiteId}/test-runs/{runId}/reports",
      "pathParams": [
        "suiteId: Guid",
        "runId: Guid"
      ],
      "query": [],
      "sorting": {
        "supportsClientProvidedSort": false,
        "serverOrder": "GeneratedAt desc, Id desc"
      },
      "response": {
        "status": 200,
        "body": "TestReportModel[]"
      },
      "problemCases": [
        "400 ProblemDetails cho non-owner access.",
        "404 khi suiteId khong ton tai."
      ],
      "notes": [
        "Khong co pagination va khong co filter theo reportType/format.",
        "Neu run hien tai chua co report nao thi response la 200 voi mang rong.",
        "Backend khong validate rieng runId co ton tai hay khong o list route; no chi doc report metadata theo runId sau khi suite access pass."
      ]
    },
    {
      "name": "GetTestRunReport",
      "method": "GET",
      "path": "/api/test-suites/{suiteId}/test-runs/{runId}/reports/{reportId}",
      "pathParams": [
        "suiteId: Guid",
        "runId: Guid",
        "reportId: Guid"
      ],
      "query": [],
      "response": {
        "status": 200,
        "body": "TestReportModel"
      },
      "problemCases": [
        "400 ProblemDetails cho non-owner access.",
        "404 khi suiteId khong ton tai hoac khong tim thay report metadata khop reportId + runId."
      ],
      "notes": [
        "Response metadata co cung coverage snapshot nhu list endpoint.",
        "NotFound hien la ProblemDetails voi detail/message prefix REPORT_NOT_FOUND."
      ]
    },
    {
      "name": "DownloadTestRunReport",
      "method": "GET",
      "path": "/api/test-suites/{suiteId}/test-runs/{runId}/reports/{reportId}/download",
      "pathParams": [
        "suiteId: Guid",
        "runId: Guid",
        "reportId: Guid"
      ],
      "query": [],
      "response": {
        "status": 200,
        "body": "DownloadBinaryResponse"
      },
      "problemCases": [
        "400 ProblemDetails cho non-owner access.",
        "404 khi suiteId khong ton tai, khong tim thay report metadata, hoac storage khong con file binary cua report."
      ],
      "notes": [
        "Response body la byte stream, khong co id/fileId/storage metadata trong body.",
        "Neu format la JSON hoac HTML va FE muon preview, co the fetch nhu blob/text thay vi bat browser download truc tiep.",
        "Report file missing trong storage hien duoc map thanh REPORT_FILE_NOT_FOUND o detail/message."
      ]
    }
  ],
  "runtimeRules": [
    "Generate report lay run context qua ITestRunReportReadGatewayService, nghia la no dung cung deterministic detailed results payload cua FE-07/08.",
    "recentHistoryLimit current host config: DefaultHistoryLimit=5, MaxHistoryLimit=20.",
    "Report retention current host config: ReportRetentionHours=168.",
    "Response body preview current host config: MaxResponseBodyPreviewChars=4000.",
    "Coverage duoc tinh tren ordered endpoint scope cua suite; failed case van tinh la tested neu endpoint da duoc thuc thi va status khong phai Skipped.",
    "Recent run history loai tru current run va lay theo RunNumber desc.",
    "Api endpoint metadata la optional; khi metadata thieu, coverage calculator fallback sang request/resolved URL va co the sinh tag untagged.",
    "JSON export serialize enum thanh string, camelCase property names, va bo qua field null.",
    "CSV export la bang phang voi cac section summary/failure_distribution/recent_runs/cases/coverage_by_method/coverage_by_tag/uncovered_paths tuy theo reportType.",
    "HTML export va PDF export dung cung template HTML; PDF la ban convert tu HTML thong qua DinkToPdf.",
    "Generate report sanitize Authorization/Cookie/token/secret/password/api key truoc khi render va truncate body preview sau sanitize.",
    "Storage upload fail se bubble loi va khong persist report metadata/coverage.",
    "Download route khong verify them run summary; no chi owner-check suite, tim report theo reportId + runId, roi download file tu Storage."
  ],
