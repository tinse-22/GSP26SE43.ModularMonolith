{
  "$schema": "frontend-api-contract",
  "version": "1.0.0",
  "documentId": "fe-12-path-parameter-templating-api",
  "validatedAgainstCodebaseOn": "2026-03-27",
  "feature": "FE-12 Path Parameter Templating",
  "controllers": [
    "SpecificationsController",
    "EndpointsController"
  ],
  "baseRoutes": [
    "/api/projects/{projectId}/specifications",
    "/api/projects/{projectId}/specifications/{specId}/endpoints"
  ],
  "authentication": {
    "required": true,
    "scheme": "Bearer"
  },
  "permissions": {
    "CreateManualSpecification": "Permission:AddSpecification",
    "ImportCurlSpecification": "Permission:AddSpecification",
    "ListEndpoints": "Permission:GetEndpoints",
    "GetEndpointDetail": "Permission:GetEndpoints",
    "CreateEndpoint": "Permission:AddEndpoint",
    "UpdateEndpoint": "Permission:UpdateEndpoint",
    "GetResolvedUrl": "Permission:GetEndpoints",
    "GetPathParamMutations": "Permission:GetEndpoints"
  },
  "placeholderRules": {
    "syntax": "{paramName}",
    "acceptedNameRegex": "^\\w+$",
    "maxPathParametersPerEndpoint": 10,
    "duplicateNameCheck": "case-insensitive",
    "resolvedUrlQueryLookup": "case-insensitive"
  },
  "enums": {
    "HttpMethod": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "PATCH",
      "HEAD",
      "OPTIONS"
    ],
    "ParameterLocation": [
      "Path",
      "Query",
      "Header",
      "Body",
      "Cookie"
    ],
    "EndpointParameterDataType": [
      "string",
      "integer",
      "number",
      "boolean",
      "object",
      "array",
      "uuid"
    ],
    "MutationTypesCommon": [
      "empty",
      "specialChars",
      "sqlInjection",
      "nonExistent"
    ],
    "MutationTypesByTypeOrFormat": [
      "wrongType",
      "boundary_zero",
      "boundary_negative",
      "boundary_float",
      "boundary_max_int32",
      "boundary_overflow_int32",
      "boundary_max_int64",
      "boundary_veryLarge",
      "boundary_verySmall",
      "numericBoolean",
      "invalidFormat",
      "partialUuid",
      "allZerosUuid",
      "missingDomain",
      "veryLong",
      "unicode",
      "whitespace"
    ]
  },
  "models": {
    "CreateManualSpecificationModel": {
      "contentType": "application/json",
      "properties": [
        {
          "name": "name",
          "type": "string",
          "required": true,
          "maxLength": 200
        },
        {
          "name": "version",
          "type": "string",
          "required": false
        },
        {
          "name": "autoActivate",
          "type": "boolean",
          "required": false
        },
        {
          "name": "endpoints",
          "type": "ManualEndpointDefinition[]",
          "required": true,
          "minItems": 1
        }
      ]
    },
    "ImportCurlModel": {
      "contentType": "application/json",
      "properties": [
        {
          "name": "name",
          "type": "string",
          "required": true,
          "maxLength": 200
        },
        {
          "name": "version",
          "type": "string",
          "required": false
        },
        {
          "name": "curlCommand",
          "type": "string",
          "required": true
        },
        {
          "name": "autoActivate",
          "type": "boolean",
          "required": false
        }
      ]
    },
    "CreateUpdateEndpointModel": {
      "contentType": "application/json",
      "properties": [
        {
          "name": "httpMethod",
          "type": "string",
          "required": true,
          "allowedValues": [
            "GET",
            "POST",
            "PUT",
            "DELETE",
            "PATCH",
            "HEAD",
            "OPTIONS"
          ]
        },
        {
          "name": "path",
          "type": "string",
          "required": true,
          "maxLength": 500
        },
        {
          "name": "operationId",
          "type": "string",
          "required": false
        },
        {
          "name": "summary",
          "type": "string",
          "required": false
        },
        {
          "name": "description",
          "type": "string",
          "required": false
        },
        {
          "name": "tags",
          "type": "string[]",
          "required": false
        },
        {
          "name": "isDeprecated",
          "type": "boolean",
          "required": false
        },
        {
          "name": "parameters",
          "type": "ManualParameterDefinition[]",
          "required": false
        },
        {
          "name": "responses",
          "type": "ManualResponseDefinition[]",
          "required": false
        }
      ],
      "notes": [
        "Backend auto-creates missing Path parameters from placeholders in path.",
        "Backend does not accept securityRequirements in create/update request body.",
        "PUT replaces all existing parameters and responses with the new payload."
      ]
    },
    "ManualEndpointDefinition": {
      "sameShapeAs": "CreateUpdateEndpointModel"
    },
    "ManualParameterDefinition": {
      "properties": [
        {
          "name": "name",
          "type": "string",
          "required": true
        },
        {
          "name": "location",
          "type": "string",
          "required": false,
          "allowedValues": [
            "Path",
            "Query",
            "Header",
            "Body",
            "Cookie"
          ]
        },
        {
          "name": "dataType",
          "type": "string enum",
          "required": false,
          "allowedValues": [
            "string",
            "integer",
            "number",
            "boolean",
            "object",
            "array",
            "uuid"
          ]
        },
        {
          "name": "format",
          "type": "string",
          "required": false
        },
        {
          "name": "isRequired",
          "type": "boolean",
          "required": false
        },
        {
          "name": "defaultValue",
          "type": "string",
          "required": false
        },
        {
          "name": "schema",
          "type": "string",
          "required": false
        },
        {
          "name": "examples",
          "type": "string",
          "required": false
        }
      ],
      "notes": [
        "dataType uses a JsonStringEnumConverter with camelCase and allowIntegerValues=false.",
        "Path parameters are validated by placeholder name and forced to isRequired=true.",
        "Unknown or missing location is normalized to Query when persisted."
      ]
    },
    "ManualResponseDefinition": {
      "properties": [
        "statusCode: int",
        "description: string?",
        "schema: string?",
        "examples: string?",
        "headers: string?"
      ]
    },
    "SpecificationDetailModel": {
      "properties": [
        "id: Guid",
        "projectId: Guid",
        "name: string",
        "sourceType: string",
        "version: string?",
        "isActive: bool",
        "parseStatus: string",
        "parsedAt: DateTimeOffset?",
        "originalFileId: Guid?",
        "createdDateTime: DateTimeOffset",
        "updatedDateTime: DateTimeOffset?",
        "endpointCount: int",
        "parseErrors: string[]?",
        "originalFileName: string?"
      ],
      "notes": [
        "Manual and cURL create responses stop at specification detail and do not inline endpoint details."
      ]
    },
    "EndpointModel": {
      "properties": [
        "id: Guid",
        "apiSpecId: Guid",
        "httpMethod: string",
        "path: string",
        "operationId: string?",
        "summary: string?",
        "description: string?",
        "tags: string?",
        "isDeprecated: bool",
        "createdDateTime: DateTimeOffset",
        "updatedDateTime: DateTimeOffset?"
      ],
      "notes": [
        "tags is a serialized JSON array string, not string[]."
      ]
    },
    "EndpointDetailModel": {
      "extends": "EndpointModel",
      "properties": [
        "resolvedUrl: string?",
        "parameters: ParameterModel[]",
        "responses: ResponseModel[]",
        "securityRequirements: SecurityReqModel[]"
      ],
      "notes": [
        "resolvedUrl is computed from persisted values only and can be null.",
        "parameters are ordered by Name ascending in the query handler."
      ]
    },
    "ParameterModel": {
      "properties": [
        "id: Guid",
        "name: string",
        "location: string",
        "dataType: string",
        "format: string?",
        "isRequired: bool",
        "defaultValue: string?",
        "schema: string?",
        "examples: string?"
      ]
    },
    "ResponseModel": {
      "properties": [
        "id: Guid",
        "statusCode: int",
        "description: string?",
        "schema: string?",
        "examples: string?",
        "headers: string?"
      ]
    },
    "SecurityReqModel": {
      "properties": [
        "id: Guid",
        "securityType: string",
        "schemeName: string?",
        "scopes: string?"
      ]
    },
    "ResolvedUrlResult": {
      "properties": [
        "originalTemplate: string",
        "resolvedUrl: string?",
        "resolvedParameters: Dictionary<string,string>",
        "unresolvedParameters: string[]",
        "isFullyResolved: bool"
      ],
      "notes": [
        "resolvedParameters contains raw values before URI encoding.",
        "resolvedUrl is null when any placeholder stays unresolved."
      ]
    },
    "PathParamMutationsResult": {
      "properties": [
        "endpointId: Guid",
        "templatePath: string",
        "totalMutations: int",
        "parameterMutations: ParameterMutationGroup[]"
      ]
    },
    "ParameterMutationGroup": {
      "properties": [
        "parameterName: string",
        "dataType: string",
        "format: string",
        "originalValue: string",
        "mutations: PathParameterMutationWithUrl[]"
      ]
    },
    "PathParameterMutationWithUrl": {
      "properties": [
        "mutationType: string",
        "label: string",
        "value: string",
        "expectedStatusCode: int",
        "description: string",
        "resolvedUrl: string?"
      ]
    },
    "ProblemDetails": {
      "contentType": "application/problem+json",
      "properties": [
        "type: string",
        "title: string",
        "status: int",
        "detail: string",
        "message: string",
        "traceId: string"
      ]
    }
  },
  "frontendFlows": [
    {
      "name": "ManualSpecWithPathTemplates",
      "steps": [
        "POST /api/projects/{projectId}/specifications/manual",
        "GET /api/projects/{projectId}/specifications/{specId}/endpoints",
        "GET /api/projects/{projectId}/specifications/{specId}/endpoints/{endpointId}",
        "Optional: GET /api/projects/{projectId}/specifications/{specId}/endpoints/{endpointId}/resolved-url?...",
        "Optional: GET /api/projects/{projectId}/specifications/{specId}/endpoints/{endpointId}/path-param-mutations"
      ]
    },
    {
      "name": "SingleEndpointCreateOrUpdate",
      "steps": [
        "POST or PUT /api/projects/{projectId}/specifications/{specId}/endpoints",
        "Use returned EndpointDetailModel as the new source of truth for auto-created path params",
        "Call GET resolved-url only when FE needs override values beyond persisted DefaultValue or Examples"
      ]
    },
    {
      "name": "CurlImportThenEnrich",
      "steps": [
        "POST /api/projects/{projectId}/specifications/curl-import",
        "GET endpoints to find the imported endpoint",
        "GET endpoint detail to inspect auto-detected path params",
        "PUT endpoint to add dataType, format, defaultValue, or examples for path params"
      ]
    }
  ],
  "endpoints": [
    {
      "name": "CreateManualSpecification",
      "method": "POST",
      "path": "/api/projects/{projectId}/specifications/manual",
      "pathParams": [
        "projectId: Guid"
      ],
      "query": [],
      "requestBody": "CreateManualSpecificationModel",
      "response": {
        "status": 201,
        "body": "SpecificationDetailModel",
        "headers": [
          "Location"
        ]
      },
      "problemCases": [
        "400 for empty name, name > 200 chars, empty endpoints, invalid HTTP method, empty path, path > 500 chars, invalid path parameter placeholder, duplicate placeholder, extra Path param not present in path, or subscription denial.",
        "404 when project does not exist."
      ],
      "notes": [
        "Validation errors for a specific endpoint are prefixed as Endpoint #n: ...",
        "Response does not include endpoint details. FE must follow up with GET endpoints/detail."
      ]
    },
    {
      "name": "ImportCurlSpecification",
      "method": "POST",
      "path": "/api/projects/{projectId}/specifications/curl-import",
      "pathParams": [
        "projectId: Guid"
      ],
      "query": [],
      "requestBody": "ImportCurlModel",
      "response": {
        "status": 201,
        "body": "SpecificationDetailModel",
        "headers": [
          "Location"
        ]
      },
      "problemCases": [
        "400 for empty name, name > 200 chars, empty curlCommand, malformed cURL, unsupported @file body reference, invalid URL, or subscription denial.",
        "404 when project does not exist."
      ],
      "notes": [
        "Import creates one specification and one endpoint.",
        "Path params are auto-detected from the imported path, but defaultValue/examples are not populated."
      ]
    },
    {
      "name": "ListEndpoints",
      "method": "GET",
      "path": "/api/projects/{projectId}/specifications/{specId}/endpoints",
      "pathParams": [
        "projectId: Guid",
        "specId: Guid"
      ],
      "query": [],
      "sorting": {
        "supportsClientProvidedSort": false,
        "serverOrder": "CreatedDateTime desc"
      },
      "response": {
        "status": 200,
        "body": "EndpointModel[]"
      },
      "notes": [
        "Use this right after manual/cURL creation to discover endpointId values."
      ]
    },
    {
      "name": "GetEndpointDetail",
      "method": "GET",
      "path": "/api/projects/{projectId}/specifications/{specId}/endpoints/{endpointId}",
      "pathParams": [
        "projectId: Guid",
        "specId: Guid",
        "endpointId: Guid"
      ],
      "query": [],
      "response": {
        "status": 200,
        "body": "EndpointDetailModel"
      },
      "notes": [
        "resolvedUrl uses DefaultValue first, then Examples[0] only.",
        "If Examples JSON is malformed, it is ignored and resolvedUrl can become null."
      ]
    },
    {
      "name": "CreateEndpoint",
      "method": "POST",
      "path": "/api/projects/{projectId}/specifications/{specId}/endpoints",
      "pathParams": [
        "projectId: Guid",
        "specId: Guid"
      ],
      "query": [],
      "requestBody": "CreateUpdateEndpointModel",
      "response": {
        "status": 201,
        "body": "EndpointDetailModel",
        "headers": [
          "Location"
        ]
      },
      "problemCases": [
        "400 for invalid body, invalid HTTP method, empty path, path too long, invalid placeholder name, duplicate placeholder, extra Path parameter not present in path, or subscription denial.",
        "404 when project/specification does not exist."
      ],
      "notes": [
        "Missing path params are auto-created with location=Path, dataType=string, isRequired=true.",
        "Returned body already reflects the merged parameter list from runtime."
      ]
    },
    {
      "name": "UpdateEndpoint",
      "method": "PUT",
      "path": "/api/projects/{projectId}/specifications/{specId}/endpoints/{endpointId}",
      "pathParams": [
        "projectId: Guid",
        "specId: Guid",
        "endpointId: Guid"
      ],
      "query": [],
      "requestBody": "CreateUpdateEndpointModel",
      "response": {
        "status": 200,
        "body": "EndpointDetailModel"
      },
      "problemCases": [
        "400 for invalid body, invalid HTTP method, empty path, path too long, invalid placeholder name, duplicate placeholder, or extra Path parameter not present in path.",
        "404 when project/specification/endpoint does not exist."
      ],
      "notes": [
        "Update fully replaces existing parameters and responses.",
        "Any path placeholders still missing after FE payload is sent are auto-created before persistence."
      ]
    },
    {
      "name": "GetResolvedUrl",
      "method": "GET",
      "path": "/api/projects/{projectId}/specifications/{specId}/endpoints/{endpointId}/resolved-url",
      "pathParams": [
        "projectId: Guid",
        "specId: Guid",
        "endpointId: Guid"
      ],
      "query": [
        "dynamic key=value pairs matching path parameter names, for example ?userId=42&orderId=abc-123"
      ],
      "response": {
        "status": 200,
        "body": "ResolvedUrlResult"
      },
      "notes": [
        "Explicit query values override persisted defaults when they are non-empty.",
        "Fallback order is explicit query value > DefaultValue > first non-empty example.",
        "Unrelated query keys are ignored."
      ]
    },
    {
      "name": "GetPathParamMutations",
      "method": "GET",
      "path": "/api/projects/{projectId}/specifications/{specId}/endpoints/{endpointId}/path-param-mutations",
      "pathParams": [
        "projectId: Guid",
        "specId: Guid",
        "endpointId: Guid"
      ],
      "query": [],
      "response": {
        "status": 200,
        "body": "PathParamMutationsResult"
      },
      "notes": [
        "Returns totalMutations=0 and an empty list when endpoint has no Path parameters.",
        "resolvedUrl inside each mutation only uses DefaultValue for sibling path params and can be null."
      ]
    }
  ],
  "runtimeRules": [
    "Backend parses placeholders from the path itself and validates them before create/update persistence.",
    "Auto-created path parameters default to dataType=string and do not receive defaultValue or examples.",
    "Known path params keep FE-provided metadata such as dataType, format, defaultValue, and examples.",
    "Path parameter names are trimmed and validated only for location=Path definitions.",
    "GetEndpointDetail computes resolvedUrl from persisted endpoint parameters only.",
    "GetResolvedUrl computes a temporary preview without mutating the database.",
    "GetResolvedUrl URI-encodes values in resolvedUrl but leaves resolvedParameters as raw strings.",
    "GetPathParamMutations returns mutation groups per persisted path parameter and does not guarantee a special FE-friendly sort order.",
    "Mutation expectedStatusCode values are heuristics from runtime service and should be rendered as backend-provided metadata.",
    "Manual and cURL creation consume endpoint quota because they create endpoints.",
    "CreateEndpoint consumes one endpoint quota; UpdateEndpoint does not re-consume quota.",
    "ValidationException responses are exposed as 400 application/problem+json with traceId."
  ],
