      },
      "responses": {
        "200": "TraceabilityMatrix",
        "404": "ProblemDetails"
      }
    }
  },
  "schemas": {
    "TestSuiteScopeModel": {
      "id": "guid",
      "projectId": "guid",
      "apiSpecId": "guid | null",
      "name": "string",
      "description": "string | null",
      "generationType": "integer GenerationType",
      "status": "integer TestSuiteStatus",
      "approvalStatus": "integer ApprovalStatus",
      "selectedEndpointIds": "guid[]",
