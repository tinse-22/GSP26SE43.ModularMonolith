  "antiMismatchChecklist": [
    "Create suite body has apiSpecId and selectedEndpointIds; no srsDocumentId.",
    "Create SRS document body has testSuiteId to attach to suite.",
    "Generate tests route is /api/test-suites/{suiteId}/generate-tests.",
    "Generation status route is /api/test-suites/{suiteId}/generation-status.",
    "Start run route is /api/test-suites/{suiteId}/test-runs.",
    "Start run returns 201, not 200.",
    "Start run response is TestRunResultModel directly, not { data: ... }.",
    "Start run uses strictValidation, not validationProfile.",
    "Start run uses retryFailedDependencies, not enableRetry.",
    "Traceability response uses requirementCode/title/testCaseName, not requirementKey/description/name.",
    "Traceability validationStatus is numeric by current serializer.",
    "AI callback body has no testSuiteId because suiteId is in the route.",
    "AI callback JSON-shaped fields are strings containing JSON."
  ]
}
