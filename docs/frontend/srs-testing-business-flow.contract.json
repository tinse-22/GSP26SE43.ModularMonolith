{
  "schemaVersion": "3.0.0",
  "documentId": "srs-testing-business-flow",
  "module": "SRS-driven testing API handoff",
  "validatedAgainstCodebaseOn": "2026-04-27",
  "baseUrl": "http://localhost:5099",
  "auth": {
    "scheme": "Bearer",
    "header": "Authorization: Bearer <JWT>",
    "requiredForFrontendEndpoints": true,
    "anonymousCallbacks": [
      "POST /api/test-suites/{suiteId}/test-cases/from-ai",
      "POST /api/srs-analysis-callback/{jobId}",
      "POST /api/srs-refinement-callback/{jobId}"
    ]
  },
  "sourceOfTruth": {
    "controllers": [
      "ClassifiedAds.Modules.TestGeneration/Controllers/TestSuitesController.cs",
      "ClassifiedAds.Modules.TestGeneration/Controllers/SrsDocumentsController.cs",
      "ClassifiedAds.Modules.TestGeneration/Controllers/TestOrderController.cs",
      "ClassifiedAds.Modules.TestGeneration/Controllers/SrsTraceabilityController.cs",
      "ClassifiedAds.Modules.TestExecution/Controllers/TestRunsController.cs"
    ],
    "requestModels": [
      "ClassifiedAds.Modules.TestGeneration/Models/Requests/CreateTestSuiteScopeRequest.cs",
      "ClassifiedAds.Modules.TestGeneration/Models/Requests/UpdateTestSuiteScopeRequest.cs",
      "ClassifiedAds.Modules.TestGeneration/Models/Requests/SrsDocumentRequests.cs",
      "ClassifiedAds.Modules.TestGeneration/Models/Requests/UpdateSrsDocumentRequest.cs",
      "ClassifiedAds.Modules.TestGeneration/Commands/SaveAiGeneratedTestCasesCommand.cs",
      "ClassifiedAds.Modules.TestExecution/Models/Requests/StartTestRunRequest.cs",
      "ClassifiedAds.Modules.TestExecution/Models/TestRunRetryPolicyModel.cs"
    ],
    "responseModels": [
      "ClassifiedAds.Modules.TestGeneration/Models/TestSuiteScopeModel.cs",
      "ClassifiedAds.Modules.TestGeneration/Models/SrsDocumentModel.cs",
      "ClassifiedAds.Modules.TestExecution/Models/TestRunResultModel.cs",
      "ClassifiedAds.Modules.TestExecution/Models/TestRunModel.cs",
      "ClassifiedAds.Modules.TestExecution/Models/TestCaseRunResultModel.cs",
      "ClassifiedAds.Modules.TestExecution/Models/TestCaseExecutionAttemptModel.cs"
    ],
    "verificationCommands": [
      "rg -n \"Route|Http(Post|Get|Patch|Put|Delete)|FromBody|FromQuery\" ClassifiedAds.Modules.TestGeneration/Controllers ClassifiedAds.Modules.TestExecution/Controllers",
      "rg -n \"public class|JsonPropertyName|public enum\" ClassifiedAds.Modules.TestGeneration ClassifiedAds.Modules.TestExecution -g \"*.cs\"",
      "PowerShell ConvertFrom-Json on this file"
    ]
  },
  "strictRulesForFrontend": [
    "Do not send srsDocumentId in POST /api/projects/{projectId}/test-suites. The backend request model does not have that field.",
    "Link an SRS document to a suite by sending testSuiteId in POST /api/projects/{projectId}/srs-documents, or by PATCH /api/projects/{projectId}/srs-documents/{srsDocumentId}.",
    "Do not call /api/projects/{projectId}/test-suites/{suiteId}/test-generation-jobs. That route does not exist.",
    "Trigger unified AI test generation with POST /api/test-suites/{suiteId}/generate-tests.",
    "Poll unified AI test generation with GET /api/test-suites/{suiteId}/generation-status?jobId={jobId}.",
    "Do not call /api/projects/{projectId}/test-suites/{suiteId}/test-runs. Test run routes do not include projectId.",
    "Start test runs with POST /api/test-suites/{suiteId}/test-runs.",
    "Do not send validationProfile in StartTestRunRequest. Current BE does not expose this field in the request model; use strictValidation=true for SRS strict behavior.",
    "Use retryFailedDependencies as the JSON key, not enableRetry. The BE maps retryFailedDependencies to EnableRetry via JsonPropertyName.",
    "StartTestRun returns HTTP 201 with TestRunResultModel directly. There is no data wrapper.",
    "Frontend should not call n8n callback endpoints directly. They are included here only so mock/n8n payloads stay correct.",
    "For n8n AI callback, headers, pathParams, queryParams, expectedStatus, bodyContains, bodyNotContains, headerChecks, jsonPathChecks are strings containing JSON, not nested JSON objects or arrays."
  ],
  "enumSerialization": {
    "requestGuideline": "Use the listed request format per field. If no JsonStringEnumConverter exists on the request property, send enum integers.",
    "responseGuideline": "Response enum properties are numeric unless the response model property itself is string.",
    "GenerationType": {
      "requestFormat": "string or integer",
      "values": {
        "Auto": 0,
        "Manual": 1,
        "LLMAssisted": 2
      }
    },
    "TestSuiteStatus": {
      "responseFormat": "integer",
      "values": {
        "Draft": 0,
        "Ready": 1,
        "Archived": 2
      }
    },
    "ApprovalStatus": {
      "responseFormat": "integer",
      "values": {
        "NotApplicable": 0,
        "PendingReview": 1,
        "Approved": 2,
        "Rejected": 3,
        "ModifiedAndApproved": 4
      }
    },
    "SrsSourceType": {
      "requestFormat": "integer",
      "values": {
        "TextInput": 0,
        "FileUpload": 1,
        "Url": 2
      }
    },
    "SrsAnalysisStatus": {
      "responseFormat": "integer",
      "values": {
        "Pending": 0,
        "Processing": 1,
        "Completed": 2,
        "Failed": 3
      }
    },
    "SrsAnalysisJobStatus": {
      "responseFormat": "integer",
      "values": {
        "Queued": 0,
        "Triggering": 1,
        "Processing": 2,
        "Completed": 3,
        "Failed": 4
      }
    },
    "SrsAnalysisJobType": {
      "responseFormat": "integer",
      "values": {
        "InitialAnalysis": 0,
        "ClarificationRefinement": 1
      }
    },
    "GenerationJobStatus": {
      "responseStringValues": [
        "Queued",
        "Triggering",
        "WaitingForCallback",
        "Completed",
        "Failed",
        "Cancelled"
      ]
    },
    "ProposalSource": {
      "requestFormat": "string or integer",
      "values": {
        "Ai": 0,
        "User": 1,
        "System": 2,
        "Imported": 3
      }
    },
    "ProposalStatus": {
      "responseFormat": "integer",
      "values": {
        "Pending": 0,
        "Approved": 1,
        "Rejected": 2,
        "ModifiedAndApproved": 3,
        "Superseded": 4,
        "Applied": 5,
        "Expired": 6
      }
    },
    "SrsRequirementType": {
      "queryFormat": "integer or enum name",
      "responseFormat": "integer",
      "values": {
        "Functional": 0,
        "NonFunctional": 1,
        "Security": 2,
        "Performance": 3,
        "Constraint": 4
      }
    },
    "RequirementValidationStatus": {
      "responseFormat": "integer",
      "values": {
        "Uncovered": 0,
        "Unverified": 1,
        "Validated": 2,
        "Violated": 3,
        "Partial": 4,
        "SkippedOnly": 5,
        "Inconclusive": 6
      }
    },
    "TestRunStatus": {
      "queryFormat": "string",
      "responseFormat": "string",
      "values": [
        "Pending",
        "Running",
        "Completed",
        "Failed",
        "Cancelled"
      ]
    },
    "ValidationProfile": {
      "exposedInStartRunRequest": false,
      "internalValues": {
        "Default": 0,
        "DemoAdaptive": 1,
        "SrsStrict": 2
      },
      "frontendInstruction": "Do not send validationProfile. Send strictValidation=true to make the command use SrsStrict internally."
    }
  },
  "businessRules": {
    "passFailSource": [
      "LLM generates test case request and expectation data only.",
      "PASS, FAIL, and SKIPPED are determined by TestExecution RuleBasedValidator and orchestration code.",
      "SRS traceability status is derived from test case links and execution evidence."
    ],
    "retryPolicy": {
      "retryableOnlyWhen": [
        "failureReasons contains HTTP_REQUEST_ERROR",
        "httpStatusCode is 408",
        "httpStatusCode is 429",
        "httpStatusCode is 5xx"
      ],
      "notRetryableByCurrentBE": [
        "STATUS_CODE_MISMATCH without transient HTTP status",
        "RESPONSE_SCHEMA_MISMATCH without transient HTTP status",
        "BODY_CONTAINS_MISSING",
        "BODY_NOT_CONTAINS_PRESENT",
        "NO_EXPECTATION",
        "INVALID_EXPECTATION_FORMAT",
        "UNRESOLVED_VARIABLE",
        "MISSING_REQUEST",
        "MISSING_BASE_URL",
        "MISSING_REQUIRED_BODY",
        "DEPENDENCY_FAILED"
      ]
    },
    "dependencySatisfaction": [
      "A dependency is satisfied when status is Passed.",
      "A dependency is also satisfied when httpStatusCode is 2xx and all failureReasons are only STATUS_CODE_MISMATCH or RESPONSE_SCHEMA_MISMATCH.",
      "Any transport error, unresolved variable, pre-execution validation failure, 4xx, 5xx, or null result blocks downstream cases."
    ],
    "traceabilityStatusFormula": [
      "No linked test cases -> Uncovered.",
      "Linked test cases exist but none has lastRunStatus -> Unverified.",
      "Any linked test case Failed -> Violated.",
      "All linked test cases Skipped and none Unverified -> SkippedOnly.",
      "All linked test cases Passed and none Skipped/Unverified -> Validated.",
      "Passed plus Skipped or Unverified, with no Failed -> Partial.",
      "Any other mix -> Inconclusive."
    ]
  },
  "businessFlow": [
    {
      "step": 1,
      "name": "Create test suite scope",
      "frontendCall": "POST /api/projects/{projectId}/test-suites",
      "save": [
        "suiteId = response.id",
        "suiteRowVersion = response.rowVersion"
      ],
      "notes": [
        "Do not send srsDocumentId here.",
        "For non-Manual suites, backend requires apiSpecId and at least one selectedEndpointIds item."
      ]
    },
    {
      "step": 2,
      "name": "Create and link SRS document",
      "frontendCall": "POST /api/projects/{projectId}/srs-documents",
      "save": [
        "srsDocumentId = response.id"
      ],
      "notes": [
        "Send testSuiteId in the SRS document body to link the document to the suite.",
        "Backend also sets TestSuite.SrsDocumentId when testSuiteId is valid."
      ]
    },
    {
      "step": 3,
      "name": "Trigger SRS analysis",
      "frontendCall": "POST /api/projects/{projectId}/srs-documents/{srsDocumentId}/analyze",
      "save": [
        "srsAnalysisJobId = response.jobId"
      ]
    },
    {
      "step": 4,
      "name": "Poll SRS analysis job",
      "frontendCall": "GET /api/projects/{projectId}/srs-documents/{srsDocumentId}/analysis-jobs/{jobId}",
      "stopWhen": [
        "status == 3 (Completed)",
        "status == 4 (Failed)"
      ]
    },
    {
      "step": 5,
      "name": "Review requirements and clarifications",
      "frontendCalls": [
        "GET /api/projects/{projectId}/srs-documents/{srsDocumentId}/requirements",
        "PATCH /api/projects/{projectId}/srs-documents/{srsDocumentId}/requirements/{requirementId}",
        "GET /api/projects/{projectId}/srs-documents/{srsDocumentId}/requirements/{requirementId}/clarifications",
        "PATCH /api/projects/{projectId}/srs-documents/{srsDocumentId}/requirements/{requirementId}/clarifications/{clarificationId}",
        "POST /api/projects/{projectId}/srs-documents/{srsDocumentId}/requirements/{requirementId}/refine"
      ]
    },
    {
      "step": 6,
      "name": "Approve API test order",
      "frontendCalls": [
        "POST /api/test-suites/{suiteId}/order-proposals",
        "GET /api/test-suites/{suiteId}/order-proposals/latest",
        "PUT /api/test-suites/{suiteId}/order-proposals/{proposalId}/reorder",
        "POST /api/test-suites/{suiteId}/order-proposals/{proposalId}/approve"
      ],
      "notes": [
        "Unified generation requires an approved or modified-and-approved order proposal."
      ]
    },
    {
      "step": 7,
      "name": "Trigger AI test generation",
      "frontendCall": "POST /api/test-suites/{suiteId}/generate-tests",
      "save": [
        "generationJobId = response.jobId"
      ]
    },
    {
      "step": 8,
      "name": "Poll AI test generation job",
      "frontendCall": "GET /api/test-suites/{suiteId}/generation-status?jobId={generationJobId}",
      "stopWhen": [
        "status == Completed",
        "status == Failed",
        "status == Cancelled"
      ]
    },
    {
      "step": 9,
      "name": "Start deterministic test run",
      "frontendCall": "POST /api/test-suites/{suiteId}/test-runs",
      "notes": [
        "For SRS compliance behavior, send strictValidation=true.",
        "Response is returned after the run finishes."
      ]
    },
    {
      "step": 10,
      "name": "View traceability matrix",
      "frontendCall": "GET /api/projects/{projectId}/test-suites/{suiteId}/traceability?testRunId={optionalRunId}",
      "notes": [
        "If testRunId is omitted, backend uses latest finished run for that suite.",
        "validationStatus is numeric RequirementValidationStatus."
      ]
    }
  ],
  "apiContracts": {
    "testSuiteCreate": {
      "method": "POST",
      "path": "/api/projects/{projectId}/test-suites",
      "auth": true,
      "pathParams": {
        "projectId": "guid required"
      },
      "requestBody": {
        "name": "string required maxLength 200",
        "description": "string optional maxLength 4000",
        "apiSpecId": "guid optional by DTO, required by handler unless generationType is Manual",
        "generationType": "GenerationType string or integer, default Auto",
        "selectedEndpointIds": "guid[] optional by DTO, required by handler unless generationType is Manual",
        "endpointBusinessContexts": "{ [endpointId: guid]: string } optional",
        "globalBusinessRules": "string optional maxLength 8000"
      },
      "doNotSend": [
        "srsDocumentId"
      ],
      "requestExample": {
        "name": "SRS Requirement Suite",
        "description": "Requirement-driven API test suite",
        "apiSpecId": "22222222-2222-2222-2222-222222222222",
        "generationType": "LLMAssisted",
        "selectedEndpointIds": [
          "33333333-3333-3333-3333-333333333333"
        ],
        "endpointBusinessContexts": {
          "33333333-3333-3333-3333-333333333333": "User must be authenticated."
        },
        "globalBusinessRules": "All error responses must use the standard envelope."
      },
      "responses": {
        "201": "TestSuiteScopeModel",
        "400": "ValidationProblemDetails or ProblemDetails"
      }
    },
    "testSuiteGet": {
      "method": "GET",
      "path": "/api/projects/{projectId}/test-suites/{suiteId}",
      "auth": true,
      "pathParams": {
        "projectId": "guid required",
        "suiteId": "guid required"
      },
      "responses": {
        "200": "TestSuiteScopeModel",
        "404": "ProblemDetails"
      }
    },
    "testSuiteUpdate": {
      "method": "PUT",
      "path": "/api/projects/{projectId}/test-suites/{suiteId}",
      "auth": true,
      "pathParams": {
        "projectId": "guid required",
        "suiteId": "guid required"
      },
      "requestBody": {
        "rowVersion": "base64 string required",
        "name": "string required maxLength 200",
        "description": "string optional maxLength 4000",
        "apiSpecId": "guid optional by DTO, required by handler unless generationType is Manual",
        "generationType": "GenerationType string or integer, default Auto",
        "selectedEndpointIds": "guid[] optional by DTO, required by handler unless generationType is Manual",
        "endpointBusinessContexts": "{ [endpointId: guid]: string } optional",
        "globalBusinessRules": "string optional maxLength 8000"
      },
      "responses": {
        "200": "TestSuiteScopeModel",
        "400": "ValidationProblemDetails or ProblemDetails",
        "404": "ProblemDetails",
        "409": "ProblemDetails for concurrency conflict"
      }
    },
    "srsDocumentCreate": {
      "method": "POST",
      "path": "/api/projects/{projectId}/srs-documents",
      "auth": true,
      "pathParams": {
        "projectId": "guid required"
      },
      "requestBody": {
        "title": "string required by handler",
        "testSuiteId": "guid nullable; when provided, must be a suite in the same project",
        "sourceType": "integer SrsSourceType; 0 TextInput, 1 FileUpload, 2 Url",
        "rawContent": "string required when sourceType=0",
        "storageFileId": "guid nullable; required when sourceType=1"
      },
      "requestExample": {
        "title": "Checkout SRS",
        "testSuiteId": "11111111-1111-1111-1111-111111111111",
        "sourceType": 0,
        "rawContent": "The system shall allow authenticated users to place orders.",
        "storageFileId": null
      },
      "responses": {
        "201": "SrsDocumentModel",
        "400": "ProblemDetails",
        "404": "ProblemDetails when testSuiteId is invalid"
      },
      "sideEffects": [
        "Creates SrsDocument.",
        "If testSuiteId is valid, sets SrsDocument.TestSuiteId and TestSuite.SrsDocumentId."
      ]
    },
    "srsDocumentPatchLink": {
      "method": "PATCH",
      "path": "/api/projects/{projectId}/srs-documents/{srsDocumentId}",
      "auth": true,
      "requestBody": {
        "testSuiteId": "guid nullable",
        "clearTestSuiteId": "boolean default false"
      },
      "responses": {
        "200": "SrsDocumentModel",
        "400": "ProblemDetails",
        "404": "ProblemDetails"
      }
    },
    "srsAnalysisTrigger": {
      "method": "POST",
      "path": "/api/projects/{projectId}/srs-documents/{srsDocumentId}/analyze",
      "auth": true,
      "requestBody": null,
      "responses": {
        "202": {
          "jobId": "guid",
          "message": "string"
        },
        "400": "ProblemDetails",
        "404": "ProblemDetails"
      }
    },
    "srsAnalysisJobGet": {
      "method": "GET",
      "path": "/api/projects/{projectId}/srs-documents/{srsDocumentId}/analysis-jobs/{jobId}",
      "auth": true,
      "responses": {
        "200": "SrsAnalysisJobModel",
        "404": "ProblemDetails"
      }
    },
    "srsRequirementsList": {
      "method": "GET",
      "path": "/api/projects/{projectId}/srs-documents/{srsDocumentId}/requirements",
      "auth": true,
      "queryParams": {
        "requirementType": "integer or enum name optional",
        "isReviewed": "boolean optional",
        "endpointId": "guid optional"
      },
      "responses": {
        "200": "SrsRequirementModel[]",
        "404": "ProblemDetails"
      }
    },
    "srsRequirementUpdate": {
      "method": "PATCH",
      "path": "/api/projects/{projectId}/srs-documents/{srsDocumentId}/requirements/{requirementId}",
      "auth": true,
      "requestBody": {
        "title": "string nullable",
        "testableConstraints": "string nullable",
        "endpointId": "guid nullable",
        "isReviewed": "boolean nullable"
      },
      "responses": {
        "200": "SrsRequirementModel",
        "400": "ProblemDetails",
        "404": "ProblemDetails"
      }
    },
    "srsClarificationsList": {
      "method": "GET",
      "path": "/api/projects/{projectId}/srs-documents/{srsDocumentId}/requirements/{requirementId}/clarifications",
      "auth": true,
      "responses": {
        "200": "SrsRequirementClarificationModel[]",
        "404": "ProblemDetails"
      }
    },
    "srsClarificationAnswer": {
      "method": "PATCH",
      "path": "/api/projects/{projectId}/srs-documents/{srsDocumentId}/requirements/{requirementId}/clarifications/{clarificationId}",
      "auth": true,
      "requestBody": {
        "userAnswer": "string nullable by DTO; should be non-empty in UI"
      },
      "responses": {
        "200": "SrsRequirementClarificationModel",
        "400": "ProblemDetails",
        "404": "ProblemDetails"
      }
    },
    "srsRequirementRefine": {
      "method": "POST",
      "path": "/api/projects/{projectId}/srs-documents/{srsDocumentId}/requirements/{requirementId}/refine",
      "auth": true,
      "requestBody": null,
      "responses": {
        "202": {
          "jobId": "guid",
          "message": "string"
        },
        "400": "ProblemDetails",
        "404": "ProblemDetails"
      }
    },
    "testOrderProposalCreate": {
      "method": "POST",
      "path": "/api/test-suites/{suiteId}/order-proposals",
      "auth": true,
      "requestBody": {
        "specificationId": "guid required",
        "selectedEndpointIds": "guid[] optional",
        "source": "ProposalSource string optional",
        "llmModel": "string optional",
        "reasoningNote": "string optional"
      },
      "responses": {
        "201": "ApiTestOrderProposalModel",
        "400": "ProblemDetails",
        "404": "ProblemDetails"
      }
    },
    "testOrderProposalApprove": {
      "method": "POST",
      "path": "/api/test-suites/{suiteId}/order-proposals/{proposalId}/approve",
      "auth": true,
      "requestBody": {
        "rowVersion": "base64 string required",
        "reviewNotes": "string optional"
      },
      "responses": {
        "200": "ApiTestOrderProposalModel",
        "400": "ProblemDetails",
        "404": "ProblemDetails",
        "409": "ProblemDetails"
      }
    },
    "testGenerationTrigger": {
      "method": "POST",
      "path": "/api/test-suites/{suiteId}/generate-tests",
      "auth": true,
      "requestBody": null,
      "responses": {
        "202": "GenerateTestsAcceptedResponse",
        "400": "ProblemDetails",
        "404": "ProblemDetails"
      }
    },
    "testGenerationStatus": {
      "method": "GET",
      "path": "/api/test-suites/{suiteId}/generation-status",
      "auth": true,
      "queryParams": {
        "jobId": "guid optional; if omitted backend uses Guid.Empty and resolves by suite behavior in query handler"
      },
      "responses": {
        "200": "GenerationJobStatusDto",
        "404": "ProblemDetails"
      }
    },
    "aiGeneratedTestCasesCallback": {
      "method": "POST",
      "path": "/api/test-suites/{suiteId}/test-cases/from-ai",
      "auth": false,
      "headers": {
        "x-callback-api-key": "required shared secret"
      },
      "frontendShouldCall": false,
      "requestBody": {
        "testCases": "AiGeneratedTestCaseDto[] required non-empty"
      },
      "responses": {
        "204": "empty",
        "400": "string error",
        "401": "empty"
      }
    },
    "testRunStart": {
      "method": "POST",
      "path": "/api/test-suites/{suiteId}/test-runs",
      "auth": true,
      "requestBody": {
        "environmentId": "guid nullable; default environment is used when null",
        "selectedTestCaseIds": "guid[] nullable; null or empty runs all enabled suite cases",
        "strictValidation": "boolean default false; true maps to internal SrsStrict",
        "retryPolicy": "TestRunRetryPolicyModel nullable; when provided, overrides scalar maxRetryAttempts/retryFailedDependencies/rerunSkippedCases",
        "maxRetryAttempts": "integer 0..3 default 3 when body object is supplied",
        "retryFailedDependencies": "boolean default true; JSON key maps to EnableRetry",
        "rerunSkippedCases": "boolean default true"
      },
      "doNotSend": [
        "validationProfile",
        "enableRetry"
      ],
      "requestExample": {
