      "responses": {
        "201": "TestRunResultModel",
        "400": "ProblemDetails",
        "404": "ProblemDetails",
        "409": "ProblemDetails"
      }
    },
    "testRunsList": {
      "method": "GET",
      "path": "/api/test-suites/{suiteId}/test-runs",
      "auth": true,
      "queryParams": {
