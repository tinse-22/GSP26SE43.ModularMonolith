{
  "$schema": "ai-agent-contract-spec",
  "version": "1.0.0",
  "documentId": "fe-07-08-contracts",
  "requirementId": "FE-07+FE-08",
  "title": "FE-07+FE-08 Contracts - Test Execution And Validation",
  "apiContracts": [
    {
      "name": "StartTestRun",
      "method": "POST",
      "route": "/api/test-suites/{suiteId}/test-runs",
      "permission": "Permission:StartTestRun",
      "requestBody": "StartTestRunRequest",
      "responseBody": "TestRunResultModel",
      "successStatus": 201,
      "description": "Bat dau mot test run moi, thuc thi ngay trong request, va tra ve summary + per-case results."
    },
    {
      "name": "GetTestRuns",
      "method": "GET",
      "route": "/api/test-suites/{suiteId}/test-runs",
      "permission": "Permission:GetTestRuns",
      "queryParams": {
        "pageNumber": "int (default: 1, min: 1)",
        "pageSize": "int (default: 20, min: 1, max: 100)",
        "status": "string? (Pending|Running|Completed|Failed|Cancelled)"
      },
      "responseBody": "PagedResult<TestRunModel>",
      "successStatus": 200,
      "description": "Run history cho mot test suite. Chi doc summary tu PostgreSQL."
    },
    {
      "name": "GetTestRun",
      "method": "GET",
      "route": "/api/test-suites/{suiteId}/test-runs/{runId}",
      "permission": "Permission:GetTestRuns",
      "responseBody": "TestRunModel",
      "successStatus": 200,
      "description": "Summary chi tiet cua 1 test run."
    },
    {
      "name": "GetTestRunResults",
      "method": "GET",
      "route": "/api/test-suites/{suiteId}/test-runs/{runId}/results",
      "permission": "Permission:GetTestRuns",
      "responseBody": "TestRunResultModel",
      "successStatus": 200,
      "description": "Chi tiet tung test case trong run. Doc payload tu distributed cache bang RedisKey."
    }
  ],
  "requestModels": [
    {
      "name": "StartTestRunRequest",
      "file": "ClassifiedAds.Modules.TestExecution/Models/Requests/StartTestRunRequest.cs",
      "fields": {
        "environmentId": {
          "type": "Guid?",
          "required": false,
          "description": "Execution environment can use. Neu null thi fallback project default environment."
        },
        "selectedTestCaseIds": {
          "type": "List<Guid>?",
          "required": false,
          "description": "Subset test cases can run. Neu null/empty thi run tat ca enabled cases trong suite."
        }
      }
    }
  ],
