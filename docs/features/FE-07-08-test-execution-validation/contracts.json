        "endpointId": "Guid?",
        "name": "string",
        "orderIndex": "int",
        "status": "string (Passed|Failed|Skipped)",
        "httpStatusCode": "int?",
        "durationMs": "long",
        "resolvedUrl": "string?",
        "requestHeaders": "Dictionary<string,string>",
        "responseHeaders": "Dictionary<string,string>",
        "responseBodyPreview": "string?",
        "failureReasons": "List<ValidationFailureModel>",
        "extractedVariables": "Dictionary<string,string>",
        "dependencyIds": "List<Guid>",
        "skippedBecauseDependencyIds": "List<Guid>"
      }
    },
    {
      "name": "ValidationFailureModel",
      "file": "ClassifiedAds.Modules.TestExecution/Models/ValidationFailureModel.cs",
      "fields": {
