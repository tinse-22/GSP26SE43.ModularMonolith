  "validationRules": [
    {
      "id": "VAL-01",
      "rule": "TestSuiteId bat buoc va khong duoc Guid.Empty.",
      "httpStatus": 400,
      "reasonCode": "INVALID_INPUT"
    },
    {
      "id": "VAL-02",
      "rule": "Suite phai ton tai va CreatedById == CurrentUserId.",
      "httpStatus": 400,
      "reasonCode": "OWNERSHIP_DENIED"
    },
    {
      "id": "VAL-03",
      "rule": "Suite phai co Status=Ready.",
      "httpStatus": 400,
      "reasonCode": "SUITE_NOT_READY"
    },
    {
      "id": "VAL-04",
      "rule": "Execution environment phai ton tai, thuoc cung project. Neu request khong co environmentId thi project phai co default environment.",
      "httpStatus": 404,
      "reasonCode": "ENVIRONMENT_NOT_FOUND"
    },
    {
      "id": "VAL-05",
      "rule": "FE-05A gate phai pass truoc khi doc execution graph.",
      "httpStatus": 409,
      "reasonCode": "ORDER_CONFIRMATION_REQUIRED"
    },
    {
      "id": "VAL-06",
      "rule": "selectedTestCaseIds phai thuoc suite, enabled, va khong duoc bo sot dependency.",
      "httpStatus": 400,
      "reasonCode": "INVALID_TEST_CASE_SELECTION"
    },
    {
      "id": "VAL-07",
      "rule": "MaxConcurrentRuns phai con du.",
      "httpStatus": 400,
      "reasonCode": "CONCURRENT_RUN_LIMIT_EXCEEDED"
    },
    {
      "id": "VAL-08",
      "rule": "MaxTestRunsPerMonth phai con du.",
      "httpStatus": 400,
      "reasonCode": "RUN_LIMIT_EXCEEDED"
    },
    {
      "id": "VAL-09",
      "rule": "GetTestRunResults bi chan neu payload da het han cache.",
      "httpStatus": 409,
      "reasonCode": "RUN_RESULTS_EXPIRED"
    }
  ],
  "errorMap": [
    {
      "httpStatus": 400,
      "reasonCode": "INVALID_INPUT",
      "exceptionType": "ValidationException",
      "description": "Input khong hop le."
    },
    {
      "httpStatus": 400,
      "reasonCode": "OWNERSHIP_DENIED",
      "exceptionType": "ValidationException",
      "description": "Current user khong duoc quyen thao tac suite nay."
    },
    {
      "httpStatus": 400,
      "reasonCode": "SUITE_NOT_READY",
      "exceptionType": "ValidationException",
      "description": "Suite chua Ready nen chua the chay."
    },
    {
      "httpStatus": 400,
      "reasonCode": "INVALID_TEST_CASE_SELECTION",
      "exceptionType": "ValidationException",
      "description": "selectedTestCaseIds co loi hoac thieu dependency."
    },
    {
      "httpStatus": 400,
      "reasonCode": "CONCURRENT_RUN_LIMIT_EXCEEDED",
      "exceptionType": "ValidationException",
      "description": "Vuot gioi han run dang chay dong thoi."
    },
    {
      "httpStatus": 400,
      "reasonCode": "RUN_LIMIT_EXCEEDED",
      "exceptionType": "ValidationException",
      "description": "Vuot gioi han so lan chay test trong thang."
    },
    {
      "httpStatus": 404,
      "reasonCode": "ENVIRONMENT_NOT_FOUND",
      "exceptionType": "NotFoundException",
      "description": "Khong tim thay execution environment yeu cau."
    },
    {
      "httpStatus": 404,
      "reasonCode": "TEST_RUN_NOT_FOUND",
      "exceptionType": "NotFoundException",
      "description": "Khong tim thay test run."
    },
    {
      "httpStatus": 409,
      "reasonCode": "ORDER_CONFIRMATION_REQUIRED",
      "exceptionType": "ConflictException",
      "description": "Chua co approved/applied API order."
    },
    {
      "httpStatus": 409,
      "reasonCode": "RUN_RESULTS_EXPIRED",
      "exceptionType": "ConflictException",
      "description": "Chi tiet ket qua da het han luu tru trong cache."
    }
  ],
  "dbWriteRules": {
    "schema": "testexecution",
    "tables": [
      "TestRuns"
    ],
    "cacheKeys": [
      "testrun:{TestRunId}:results"
    ],
    "transactionBoundary": "Chi dung transaction de allocate RunNumber va insert Pending TestRun. Save result detail vao cache va update summary sau execution.",
    "notes": [
      "Khong tao bang TestCaseResults moi trong PostgreSQL.",
      "RedisKey duoc dat ngay khi tao run record.",
      "ResultsExpireAt phai bang UtcNow + retentionDays.",
      "Neu cache write fail thi van update run final status = Failed va log loi."
    ]
  },
  "securityAndAuthorization": {
    "permissionsToAdd": [
      "Permission:StartTestRun",
      "Permission:GetTestRuns"
    ],
    "requirements": [
      "POST /test-runs yeu cau [Authorize(Permissions.StartTestRun)].",
      "GET endpoints yeu cau [Authorize(Permissions.GetTestRuns)].",
      "Query/command handlers phai verify current user co the doc/thuc thi suite thong qua ownership context."
    ]
  }
}
