        "target": "string?",
        "expected": "string?",
        "actual": "string?"
      }
    }
  ],
  "internalContracts": {
    "commands": [
      {
        "name": "StartTestRunCommand",
        "file": "ClassifiedAds.Modules.TestExecution/Commands/StartTestRunCommand.cs",
        "handler": "StartTestRunCommandHandler",
        "inputFields": {
          "testSuiteId": "Guid",
          "currentUserId": "Guid",
          "environmentId": "Guid?",
          "selectedTestCaseIds": "IReadOnlyList<Guid>?"
        },
        "outputField": "Result: TestRunResultModel",
        "reads": [
          "TestRun (max RunNumber for suite, running count for user, summary reload)",
          "ExecutionEnvironment (by id or default project environment)"
        ],
        "crossModuleReads": [
          "ITestExecutionReadGatewayService.GetSuiteAccessContextAsync(testSuiteId)",
          "ITestExecutionReadGatewayService.GetExecutionContextAsync(testSuiteId, selectedTestCaseIds)",
          "IApiEndpointMetadataService.GetEndpointMetadataAsync(specId, endpointIds)",
          "ISubscriptionLimitGatewayService.CheckLimitAsync(MaxConcurrentRuns, runningCount + 1)",
          "ISubscriptionLimitGatewayService.CheckLimitAsync(RetentionDays, 0)",
          "ISubscriptionLimitGatewayService.TryConsumeLimitAsync(MaxTestRunsPerMonth, 1)"
        ],
        "writes": [
          "TestRun insert (Pending)",
          "TestRun update (Running -> Completed/Failed, counters, duration, RedisKey, ResultsExpireAt)"
        ],
        "transactionRequired": true,
        "transactionScope": "Serializable chi cho cap RunNumber va insert Pending run. Execution loop khong nam trong DB transaction."
      }
    ],
    "queries": [
      {
        "name": "GetTestRunsQuery",
        "file": "ClassifiedAds.Modules.TestExecution/Queries/GetTestRunsQuery.cs",
        "handler": "GetTestRunsQueryHandler",
        "inputFields": {
          "testSuiteId": "Guid",
          "currentUserId": "Guid",
          "pageNumber": "int",
          "pageSize": "int",
          "status": "TestRunStatus?"
        },
        "reads": [
          "TestRun projection with paging only"
        ]
      },
      {
        "name": "GetTestRunQuery",
        "file": "ClassifiedAds.Modules.TestExecution/Queries/GetTestRunQuery.cs",
        "handler": "GetTestRunQueryHandler",
        "inputFields": {
          "testSuiteId": "Guid",
          "runId": "Guid",
          "currentUserId": "Guid"
        },
        "reads": [
          "Single TestRun summary"
        ]
      },
      {
        "name": "GetTestRunResultsQuery",
        "file": "ClassifiedAds.Modules.TestExecution/Queries/GetTestRunResultsQuery.cs",
        "handler": "GetTestRunResultsQueryHandler",
        "inputFields": {
          "testSuiteId": "Guid",
          "runId": "Guid",
          "currentUserId": "Guid"
        },
        "reads": [
          "Single TestRun summary",
          "1 distributed cache entry via RedisKey"
        ]
      }
    ],
    "services": [
      {
        "name": "ITestExecutionReadGatewayService",
        "project": "ClassifiedAds.Contracts",
        "file": "ClassifiedAds.Contracts/TestGeneration/Services/ITestExecutionReadGatewayService.cs",
        "implementation": "TestExecutionReadGatewayService",
        "implementationFile": "ClassifiedAds.Modules.TestGeneration/Services/TestExecutionReadGatewayService.cs",
        "methods": [
          {
            "name": "GetSuiteAccessContextAsync",
            "signature": "Task<TestSuiteAccessContextDto> GetSuiteAccessContextAsync(Guid testSuiteId, CancellationToken ct)",
            "description": "Tra ve suite ownership/project/spec/status context toi gian."
          },
          {
            "name": "GetExecutionContextAsync",
            "signature": "Task<TestSuiteExecutionContextDto> GetExecutionContextAsync(Guid testSuiteId, IReadOnlyCollection<Guid> selectedTestCaseIds, CancellationToken ct)",
            "description": "Tra ve ordered enabled test case graph, enforce FE-05A gate, selection validity, dependency completeness."
          }
        ]
      },
      {
        "name": "ITestExecutionOrchestrator",
        "file": "ClassifiedAds.Modules.TestExecution/Services/ITestExecutionOrchestrator.cs",
        "implementation": "TestExecutionOrchestrator",
        "methods": [
          {
            "name": "ExecuteAsync",
            "signature": "Task<TestRunResultModel> ExecuteAsync(Guid testRunId, Guid currentUserId, IReadOnlyCollection<Guid> selectedTestCaseIds, CancellationToken ct)",
            "description": "Main orchestration: load execution context, run sequentially, validate, collect results."
          }
        ]
      },
      {
        "name": "IExecutionEnvironmentRuntimeResolver",
        "file": "ClassifiedAds.Modules.TestExecution/Services/IExecutionEnvironmentRuntimeResolver.cs",
        "implementation": "ExecutionEnvironmentRuntimeResolver",
        "methods": [
          {
            "name": "ResolveAsync",
            "signature": "Task<ResolvedExecutionEnvironment> ResolveAsync(ExecutionEnvironment environment, CancellationToken ct)",
            "description": "Build runtime headers/query params/auth material once per run. OAuth2 token resolution lives here, not in HttpTestExecutor."
          }
        ]
      },
      {
        "name": "IVariableResolver",
        "file": "ClassifiedAds.Modules.TestExecution/Services/IVariableResolver.cs",
        "implementation": "VariableResolver",
        "methods": [
          {
            "name": "Resolve",
            "signature": "ResolvedTestCaseRequest Resolve(ExecutionTestCaseDto testCase, IReadOnlyDictionary<string,string> variables, ResolvedExecutionEnvironment environment)",
            "description": "Resolve placeholders va path template, merge environment defaults, clamp timeout."
          }
        ]
      },
      {
        "name": "IHttpTestExecutor",
        "file": "ClassifiedAds.Modules.TestExecution/Services/IHttpTestExecutor.cs",
        "implementation": "HttpTestExecutor",
        "methods": [
          {
            "name": "ExecuteAsync",
            "signature": "Task<HttpTestResponse> ExecuteAsync(ResolvedTestCaseRequest request, CancellationToken ct)",
            "description": "Gui HTTP request that su va thu thap response body/header/status/latency."
          }
        ]
      },
      {
        "name": "IVariableExtractor",
        "file": "ClassifiedAds.Modules.TestExecution/Services/IVariableExtractor.cs",
        "implementation": "VariableExtractor",
        "methods": [
          {
            "name": "Extract",
            "signature": "IReadOnlyDictionary<string,string> Extract(HttpTestResponse response, IReadOnlyList<ExecutionVariableRuleDto> variables)",
            "description": "Extract values tu response body/header/status voi fallback DefaultValue."
          }
        ]
      },
      {
        "name": "IRuleBasedValidator",
        "file": "ClassifiedAds.Modules.TestExecution/Services/IRuleBasedValidator.cs",
        "implementation": "RuleBasedValidator",
        "methods": [
          {
            "name": "Validate",
            "signature": "TestCaseValidationResult Validate(HttpTestResponse response, ExecutionTestCaseDto testCase, ApiEndpointMetadataDto endpointMetadata = null)",
            "description": "Deterministic pass/fail evaluation."
          }
        ]
      },
      {
        "name": "ITestResultCollector",
        "file": "ClassifiedAds.Modules.TestExecution/Services/ITestResultCollector.cs",
        "implementation": "TestResultCollector",
        "methods": [
          {
            "name": "CollectAsync",
            "signature": "Task<TestRunResultModel> CollectAsync(TestRun run, IReadOnlyList<TestCaseExecutionResult> caseResults, int retentionDays, string environmentName, CancellationToken ct)",
            "description": "Save cache payload, update TestRun summary, return API model."
          }
        ]
      }
    ]
  },
