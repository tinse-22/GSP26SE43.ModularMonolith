  "queryOptimization": {
    "mandatory": [
      "Gateway phai doc execution graph bang batch queries va in-memory maps.",
      "GetTestRuns list phai paging + projection, khong materialize full entity list khong can thiet.",
      "Khong duoc parse response schema payload trong loop neu endpoint metadata trung lap; phai cache per endpoint trong scope mot run.",
      "OAuth2 token phai resolve 1 lan moi run.",
      "Khong duoc tao HttpClient moi request; phai dung IHttpClientFactory."
    ],
    "forbidden": [
      "Repository.FirstOrDefaultAsync trong loop testCaseIds.",
      "Direct LINQ query moi test case de doc request/expectation/dependency.",
      "Load run history roi filter/page trong memory."
    ]
  },
  "flows": [
    {
      "name": "Execution Surface",
      "steps": [
        "1. Controller dispatch StartTestRunCommand.",
        "2. Handler validate suite/environment/limits and create Pending TestRun.",
        "3. Orchestrator load execution graph + endpoint metadata + runtime environment.",
        "4. Sequentially resolve request -> execute HTTP -> extract vars -> validate -> accumulate result.",
        "5. Collector save cache payload and update TestRun summary."
      ]
    },
    {
      "name": "Read Surface",
      "steps": [
        "1. GetTestRunsQuery tra summary co paging.",
        "2. GetTestRunQuery tra mot summary.",
        "3. GetTestRunResultsQuery tra detailed payload tu cache."
      ]
    }
  ],
  "qualityGates": [
    "Khong them migration, entity, hoac DbSet moi.",
    "Khong direct reference TestGeneration entities trong TestExecution.",
    "Khong N+1 query trong gateway.",
    "Khong cho auth injection override request-level negative auth cases.",
    "Khong luu response body khong gioi han vao cache."
  ],
  "testPlan": {
    "unitTests": [
      "TestExecutionReadGatewayServiceTests (selection, dependency closure, ordering, gate fail).",
      "ExecutionEnvironmentRuntimeResolverTests (Bearer/Basic/ApiKey/OAuth2/default headers precedence).",
      "VariableResolverTests (URL/path/query/header/body placeholder resolution, unresolved variable fail).",
      "HttpTestExecutorTests (baseUrl join, timeout clamp, header/query merge, transport error handling).",
      "VariableExtractorTests (JSONPath/header/status extraction + default value fallback).",
      "RuleBasedValidatorTests (status/schema/header/body/jsonpath/response time).",
      "TestResultCollectorTests (cache payload save, summary counters, expiry handling).",
      "StartTestRunCommandHandlerTests (suite/env/limit validation, run number allocation, orchestration call)."
    ],
    "integrationTests": [
      "Start run happy path end-to-end voi TestServer/handler stub, verify TestRun summary update + cache payload.",
      "Dependency fail -> dependents skipped.",
      "EnvironmentId null -> project default environment duoc dung.",
      "GetTestRunResults after expiry -> RUN_RESULTS_EXPIRED.",
      "Gateway + validator with generated happy-path/boundary suite data."
    ]
  },
  "implementationSequence": [
    "1. Contracts/TestGeneration gateway DTOs + interface",
