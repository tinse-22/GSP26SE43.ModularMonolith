        "endpoint": "POST /api/test-suites/{suiteId}/test-cases"
      },
      {
        "id": "CHK-03",
        "area": "Create TestCase",
        "check": "expectation.headerChecks gửi lên là '{\"Content-Type\":\"application/json\"}' (JSON object string), không phải object native.",
        "endpoint": "POST /api/test-suites/{suiteId}/test-cases"
      },
      {
        "id": "CHK-04",
        "area": "Create TestCase",
        "check": "expectation.jsonPathChecks gửi lên là '{\"$.id\":\"not_null\"}' (JSON object string).",
        "endpoint": "POST /api/test-suites/{suiteId}/test-cases"
      },
      {
