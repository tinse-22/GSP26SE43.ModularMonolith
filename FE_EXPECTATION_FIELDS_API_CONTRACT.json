        "endpoint": "PUT /api/test-suites/{suiteId}/llm-suggestions/{suggestionId}/review"
      },
      {
        "id": "CHK-08",
        "area": "LLM Review",
        "check": "reviewNotes là required khi action = 'Reject'. Nếu thiếu sẽ bị 400.",
        "endpoint": "PUT /api/test-suites/{suiteId}/llm-suggestions/{suggestionId}/review"
      },
      {
        "id": "CHK-09",
        "area": "TestRun Result",
        "check": "cases[].bodyContainsPassed = true/false. Nếu null thì check đã bị skip (field rỗng).",
        "endpoint": "GET /api/test-suites/{suiteId}/test-runs/{runId}/results"
      },
      {
