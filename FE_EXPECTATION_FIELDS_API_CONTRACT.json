{
  "title": "FE — Expectation Fields Full API Flow Contract",
  "description": "Tài liệu kiểm tra toàn bộ luồng của các field expectation (BodyContains, BodyNotContains, ExpectedStatus, ResponseSchema, HeaderChecks, JsonPathChecks, MaxResponseTime) từ khi tạo đến khi validate kết quả test run. FE dùng file này để verify API đã nối đúng và param đúng format.",
  "generatedAt": "2026-04-25",
  "schemaVersion": "1.0.0",

  "fieldFormats": {
    "note": "TẤT CẢ expectation fields đều là string khi truyền vào API (application/json). Nội dung bên trong phải là JSON string đã serialize.",
    "expectedStatus": {
      "backendType": "string",
      "internalFormat": "JSON array of integers",
      "example": "[200, 201]",
      "invalidExample": "200",
      "note": "Nếu truyền string thô (không phải JSON array) sẽ bị validator đánh là INVALID_EXPECTATION_FORMAT."
    },
    "responseSchema": {
      "backendType": "string",
      "internalFormat": "JSON Schema object string (draft-07 compatible)",
      "example": "{\"type\":\"object\",\"properties\":{\"id\":{\"type\":\"string\"}}}",
      "note": "Nếu null/empty thì schema check bị skip. Schema fallback từ ApiEndpointMetadata có thể được dùng nếu expected status là 2xx."
    },
    "headerChecks": {
      "backendType": "string",
      "internalFormat": "JSON object { headerName: expectedValue }",
      "example": "{\"Content-Type\":\"application/json\",\"X-Request-Id\":\"abc\"}",
      "note": "Key compare case-insensitive. Value compare exact after trim."
    },
    "bodyContains": {
      "backendType": "string",
      "internalFormat": "JSON array of strings — mỗi phần tử là một substring phải có trong response body",
      "example": "[\"success\", \"\\\"id\\\"\"]",
      "note": "So khớp bằng StringComparison.Ordinal (case-sensitive, exact substring). Nếu truyền array rỗng [] thì check bị skip."
    },
    "bodyNotContains": {
      "backendType": "string",
      "internalFormat": "JSON array of strings — mỗi phần tử là substring KHÔNG được có trong response body",
      "example": "[\"error\", \"forbidden\"]",
      "note": "So khớp bằng StringComparison.Ordinal. Nếu truyền array rỗng [] thì check bị skip."
    },
    "jsonPathChecks": {
      "backendType": "string",
      "internalFormat": "JSON object { jsonPath: expectedValue }",
      "example": "{\"$.id\":\"not_null\",\"$.items[0].name\":\"Alice\"}",
      "supportedSpecialValues": ["not_null", "null", "exists", "not_exists"],
      "note": "JSONPath subset: $, $.prop, $.prop.nested, $.items[0]. Không dùng Newtonsoft."
    },
    "maxResponseTime": {
      "backendType": "integer | null",
      "unit": "milliseconds",
      "example": 3000,
      "note": "Nếu null thì response time check bị skip."
    }
  },

  "flows": [
    {
      "id": "FLOW-A",
      "name": "Manual TestCase Creation",
      "description": "FE tự nhập và gửi test case thủ công qua API. Expectation fields phải là JSON string đã serialize đúng format.",
      "steps": [
        {
          "step": 1,
          "name": "POST CreateTestCase",
          "method": "POST",
          "url": "/api/test-suites/{suiteId}/test-cases",
          "auth": true,
          "permission": "Permission:AddTestCase",
          "contentType": "application/json",
          "requestBody": {
            "endpointId": "guid | null",
            "name": "string (required)",
            "description": "string",
            "testType": "HappyPath | Boundary | Negative | Performance | Security",
            "priority": "Critical | High | Medium | Low",
            "isEnabled": true,
            "tags": ["string"],
            "request": {
              "httpMethod": "GET | POST | PUT | DELETE | PATCH",
              "url": "string",
              "headers": "JSON object string | null",
              "pathParams": "JSON object string | null",
              "queryParams": "JSON object string | null",
              "bodyType": "None | Json | FormData | FormUrlEncoded | Raw",
              "body": "string | null",
              "timeout": 30000
            },
            "expectation": {
              "expectedStatus": "[200, 201]",
              "responseSchema": "{\"type\":\"object\"}",
              "headerChecks": "{\"Content-Type\":\"application/json\"}",
              "bodyContains": "[\"success\"]",
              "bodyNotContains": "[\"error\"]",
              "jsonPathChecks": "{\"$.id\":\"not_null\"}",
              "maxResponseTime": 3000
            },
            "variables": [
              {
                "variableName": "access_token",
                "extractFrom": "ResponseBody",
                "jsonPath": "$.token",
                "headerName": null,
                "regex": null,
                "defaultValue": null
              }
            ]
          },
          "responses": {
            "201": {
              "description": "Created. Body = TestCaseModel.",
              "shape": "$ref: #/schemas/TestCaseModel"
            },
            "400": "Validation error — tên thiếu, format JSON sai, suiteId không tồn tại.",
            "404": "Suite không tìm thấy."
          },
          "commonMistakes": [
            "Truyền expectedStatus='200' (string thô) thay vì '[200]' (JSON array string) → lỗi INVALID_EXPECTATION_FORMAT khi chạy.",
            "Truyền bodyContains='success' thay vì '[\"success\"]' → JSON parse fail → check bị coi là fail.",
            "Bỏ trống expectation object (không gửi key) → tất cả checks bị skip khi chạy → pass không có gì đảm bảo."
          ]
        },
        {
          "step": 2,
          "name": "GET VerifyCreated",
          "method": "GET",
          "url": "/api/test-suites/{suiteId}/test-cases/{testCaseId}",
          "auth": true,
          "permission": "Permission:GetTestCases",
          "description": "Đọc lại để confirm expectation fields đã lưu đúng.",
          "responses": {
            "200": {
              "description": "TestCaseModel đầy đủ.",
              "shape": "$ref: #/schemas/TestCaseModel"
            },
            "404": "Không tìm thấy hoặc không thuộc suite này."
          },
          "checkPoints": [
            "response.expectation.bodyContains phải là '[\"success\"]' (JSON array string), không phải 'success'.",
            "response.expectation.expectedStatus phải là '[200]' hoặc '[200, 201]'.",
            "response.expectation.headerChecks phải là JSON object string hoặc null."
          ]
        }
      ]
    },

    {
      "id": "FLOW-B",
      "name": "LLM Suggestion — Generate → Review → Accept",
      "description": "LLM sinh suggestion, FE hiển thị để user review, user có thể modify trước khi accept. Khi accept, suggestion được vật chất hóa thành TestCase thật.",
      "steps": [
        {
          "step": 1,
          "name": "POST GenerateLlmSuggestionPreview",
          "method": "POST",
          "url": "/api/test-suites/{suiteId}/llm-suggestions/generate",
          "auth": true,
          "permission": "Permission:GenerateBoundaryNegativeTestCases",
          "contentType": "application/json",
          "requestBody": {
            "specificationId": "guid | null",
            "forceRefresh": false,
            "algorithmProfile": {
              "note": "Optional. Cấu hình thuật toán sinh suggestion."
            }
          },
          "responses": {
            "201": "GenerateLlmSuggestionPreviewResultModel — danh sách suggestion đã tạo.",
            "400": "Validation error.",
            "404": "Suite không tồn tại.",
            "409": "Đã có job đang chạy."
          }
        },
        {
          "step": 2,
          "name": "GET ListSuggestions",
          "method": "GET",
          "url": "/api/test-suites/{suiteId}/llm-suggestions",
          "auth": true,
          "permission": "Permission:GetTestCases",
          "queryParams": {
            "reviewStatus": "Pending | Approved | Rejected | null",
            "testType": "HappyPath | Boundary | Negative | null",
            "endpointId": "guid | null",
            "includeDeleted": false
          },
          "responses": {
            "200": "List<LlmSuggestionModel>"
          },
          "checkPoints": [
            "suggestion.content.expectation.bodyContains — đây là List<string> ở dạng gốc từ LLM, không phải string.",
            "FE cần convert sang JSON string trước khi gửi lên review nếu có modify."
          ]
        },
        {
          "step": 3,
          "name": "PUT ReviewSuggestion (Approve / Reject / Modify+Approve)",
          "method": "PUT",
          "url": "/api/test-suites/{suiteId}/llm-suggestions/{suggestionId}/review",
          "auth": true,
          "permission": "Permission:UpdateTestCase",
          "contentType": "application/json",
          "requestBody": {
            "action": "Approve | Reject | Modify",
            "rowVersion": "base64 string (required — lấy từ GET suggestion response)",
            "reviewNotes": "string (required khi action=Reject)",
            "modifiedContent": {
              "note": "Required khi action=Modify. Nếu action=Approve thì để null.",
              "name": "string",
              "description": "string",
              "testType": "HappyPath | Boundary | Negative | Performance | Security",
              "priority": "Critical | High | Medium | Low",
              "tags": ["string"],
              "request": {
                "httpMethod": "string",
                "url": "string",
                "headers": { "key": "value" },
                "pathParams": { "key": "value" },
                "queryParams": { "key": "value" },
                "bodyType": "string",
                "body": "string",
                "timeout": 30000
              },
              "expectation": {
                "expectedStatus": [200, 201],
                "responseSchema": "JSON Schema string",
                "headerChecks": { "Content-Type": "application/json" },
                "bodyContains": ["success"],
                "bodyNotContains": ["error"],
                "jsonPathChecks": { "$.id": "not_null" },
                "maxResponseTime": 3000
              },
              "variables": [
                {
                  "variableName": "string",
                  "extractFrom": "string",
                  "jsonPath": "string",
                  "headerName": null,
                  "regex": null,
                  "defaultValue": null
                }
              ]
            }
          },
          "importantNote": "Trong modifiedContent.expectation, các field (bodyContains, bodyNotContains, headerChecks, jsonPathChecks) là kiểu NATIVE (List<string>, Dict<string,string>) — KHÁC với AddTestCaseRequest dùng string JSON. BE tự serialize nội bộ khi materialize.",
          "responses": {
            "200": "LlmSuggestionModel — suggestion sau khi review.",
            "400": "Validation error (rowVersion thiếu, action không hợp lệ, reviewNotes thiếu khi Reject).",
            "404": "Suggestion không tồn tại.",
            "409": "RowVersion conflict — suggestion đã bị sửa bởi request khác."
          }
        },
        {
          "step": 4,
          "name": "POST BulkReview (FE-17)",
          "method": "POST",
          "url": "/api/test-suites/{suiteId}/llm-suggestions/bulk-review",
          "auth": true,
          "permission": "Permission:UpdateTestCase",
          "contentType": "application/json",
          "requestBody": {
            "action": "Approve | Reject",
            "reviewNotes": "string (required khi action=Reject)",
            "filterBySuggestionType": "string | null",
            "filterByTestType": "HappyPath | Boundary | Negative | null",
            "filterByEndpointId": "guid | null"
          },
          "responses": {
            "200": "BulkReviewLlmSuggestionsResultModel — { approved, rejected, skipped }",
            "400": "Validation error.",
            "404": "Suite không tồn tại.",
            "409": "Concurrency conflict."
          }
        }
      ]
    },

    {
      "id": "FLOW-C",
      "name": "Update Existing TestCase",
      "description": "FE edit test case đã tạo (kể cả expectation fields). Cùng format với AddTestCase.",
      "steps": [
        {
          "step": 1,
          "name": "PUT UpdateTestCase",
          "method": "PUT",
          "url": "/api/test-suites/{suiteId}/test-cases/{testCaseId}",
          "auth": true,
          "permission": "Permission:UpdateTestCase",
          "contentType": "application/json",
          "requestBody": {
            "note": "Cùng shape với AddTestCaseRequest. Expectation fields phải là JSON string serialize đúng format.",
            "expectation": {
              "expectedStatus": "[200]",
              "responseSchema": null,
              "headerChecks": null,
              "bodyContains": "[\"success\"]",
              "bodyNotContains": "[\"error\"]",
              "jsonPathChecks": null,
              "maxResponseTime": null
            }
          },
          "responses": {
            "200": "TestCaseModel updated.",
            "400": "Validation error.",
            "404": "TestCase không tồn tại."
          }
        }
      ]
    },

    {
      "id": "FLOW-D",
      "name": "Read TestCases",
      "description": "FE đọc danh sách hoặc chi tiết test case để hiển thị / prefill form.",
      "endpoints": [
        {
          "name": "GetAll",
          "method": "GET",
          "url": "/api/test-suites/{suiteId}/test-cases",
          "auth": true,
          "permission": "Permission:GetTestCases",
          "queryParams": {
            "testType": "HappyPath | Boundary | Negative | Performance | Security | null",
            "includeDisabled": false,
            "includeDeleted": false
          },
          "responses": {
            "200": "List<TestCaseModel>",
            "404": "Suite không tồn tại."
          }
        },
        {
          "name": "GetById",
          "method": "GET",
          "url": "/api/test-suites/{suiteId}/test-cases/{testCaseId}",
          "auth": true,
          "permission": "Permission:GetTestCases",
          "responses": {
            "200": "TestCaseModel",
            "404": "Không tìm thấy."
          }
        }
      ]
    },

    {
      "id": "FLOW-E",
      "name": "Execute TestRun và đọc kết quả validation",
      "description": "Sau khi test cases đã có expectation đúng, FE trigger run và đọc kết quả để biết từng check pass/fail như thế nào.",
      "steps": [
        {
          "step": 1,
          "name": "POST StartTestRun",
          "method": "POST",
          "url": "/api/test-suites/{suiteId}/test-runs",
          "auth": true,
          "permission": "Permission:StartTestRun",
          "contentType": "application/json",
          "requestBody": {
            "environmentId": "guid | null",
            "selectedTestCaseIds": ["guid"],
            "strictValidation": false,
            "retryPolicy": {
              "maxRetryAttempts": 0,
              "retryFailedDependencies": true,
              "rerunSkippedCases": true
            }
          },
          "responses": {
            "201": "TestRunResultModel — kết quả đầy đủ sau khi run hoàn thành.",
            "400": "Validation error.",
            "404": "Suite/environment không tìm thấy.",
            "409": "Concurrent run limit hoặc monthly quota."
          },
          "note": "Long-running. Response trả về SAU KHI toàn bộ run hoàn thành."
        },
        {
          "step": 2,
          "name": "GET TestRunResults",
          "method": "GET",
          "url": "/api/test-suites/{suiteId}/test-runs/{runId}/results",
          "auth": true,
          "permission": "Permission:GetTestRuns",
          "responses": {
            "200": "TestRunResultModel",
            "404": "Run không tìm thấy.",
            "409": "Run vẫn đang chạy."
          }
        }
      ]
    }
  ],

