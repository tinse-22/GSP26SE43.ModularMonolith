  "validationBehavior": {
    "description": "RuleBasedValidator chạy 7 check độc lập. Mỗi check có thể: performed (chạy và pass/fail) hoặc skipped (field trống/null). IsPassed = failures.length === 0.",
    "checks": [
      {
        "id": 1,
        "field": "expectedStatus",
        "skipCondition": "null hoặc empty string",
        "failCondition": "response.statusCode không nằm trong mảng",
        "failureCode": "STATUS_CODE_MISMATCH",
        "invalidFormatCode": "INVALID_EXPECTATION_FORMAT"
      },
      {
        "id": 2,
        "field": "responseSchema",
        "skipCondition": "null hoặc empty. Schema fallback được dùng nếu expected status là 2xx và endpoint có ResponseSchemaPayloads",
        "failCondition": "response body không conform JSON Schema",
        "failureCode": "SCHEMA_MISMATCH | RESPONSE_NOT_JSON",
        "strictModeNote": "strictValidation=true: schema mismatch → fail. strictValidation=false (default): schema mismatch → warning, không fail."
      },
      {
        "id": 3,
        "field": "headerChecks",
        "skipCondition": "null hoặc empty string",
        "failCondition": "header không có hoặc value không khớp",
        "failureCode": "HEADER_VALUE_MISMATCH | HEADER_MISSING",
        "invalidFormatCode": "INVALID_EXPECTATION_FORMAT"
      },
      {
        "id": 4,
        "field": "bodyContains",
        "skipCondition": "null, empty string, hoặc JSON array rỗng []",
        "failCondition": "response.body KHÔNG chứa một trong các substring (case-sensitive)",
        "failureCode": "BODY_CONTAINS_MISSING",
        "invalidFormatCode": "INVALID_EXPECTATION_FORMAT",
        "note": "Mỗi pattern thiếu tạo ra một failure riêng."
      },
      {
        "id": 5,
        "field": "bodyNotContains",
        "skipCondition": "null, empty string, hoặc JSON array rỗng []",
        "failCondition": "response.body CÓ chứa một trong các substring (case-sensitive)",
        "failureCode": "BODY_NOT_CONTAINS_PRESENT",
        "invalidFormatCode": "INVALID_EXPECTATION_FORMAT"
      },
      {
        "id": 6,
        "field": "jsonPathChecks",
        "skipCondition": "null hoặc empty string",
        "failCondition": "JSONPath không tìm thấy hoặc value không khớp",
        "failureCode": "JSONPATH_ASSERTION_FAILED | PATH_NOT_FOUND | RESPONSE_NOT_JSON",
        "invalidFormatCode": "INVALID_EXPECTATION_FORMAT"
      },
      {
        "id": 7,
        "field": "maxResponseTime",
        "skipCondition": "null",
        "failCondition": "response.latencyMs > maxResponseTime",
        "failureCode": "RESPONSE_TIME_EXCEEDED"
      }
    ],
    "specialCodes": {
      "ALL_CHECKS_SKIPPED": "Warning khi checksPerformed = 0 và checksSkipped > 0. IsPassed vẫn = true.",
      "TRANSPORT_ERROR": "Fail ngay nếu có lỗi network/HTTP. Không chạy bất kỳ check nào."
    }
  },

  "checklist": {
    "description": "FE dùng danh sách này để verify từng điểm nối API.",
    "items": [
      {
