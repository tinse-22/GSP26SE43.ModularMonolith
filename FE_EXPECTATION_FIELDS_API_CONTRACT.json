        "area": "Create TestCase",
        "check": "expectation.expectedStatus gửi lên là '[200]' (JSON array string), không phải 200 (number) hay '200' (plain string).",
        "endpoint": "POST /api/test-suites/{suiteId}/test-cases"
      },
      {
        "id": "CHK-02",
        "area": "Create TestCase",
