ASPNETCORE_ENVIRONMENT=Production
DOTNET_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:8080
PORT=8080

# Database (required)
ConnectionStrings__Default=Host=db.YOUR_SUPABASE_PROJECT_REF.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_SUPABASE_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true;Timeout=30;Command Timeout=60
CheckDependency__Enabled=true
CheckDependency__Host=db.YOUR_SUPABASE_PROJECT_REF.supabase.co:5432
Modules__Identity__ConnectionStrings__CommandTimeout=60

# Database (for docker compose / standalone mode)
STANDALONE_DATABASE_MODE=external
SUPABASE_CONNECTION_STRING=Host=db.YOUR_SUPABASE_PROJECT_REF.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_SUPABASE_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true;Timeout=30;Command Timeout=60
SUPABASE_CHECKDEPENDENCY_HOST=db.YOUR_SUPABASE_PROJECT_REF.supabase.co:5432

# Cache
Caching__Distributed__Provider=Redis
Caching__Distributed__Redis__Configuration=rediss://default:YOUR_RENDER_REDIS_PASSWORD@YOUR_RENDER_REDIS_HOST:6379/0
Caching__Distributed__Redis__InstanceName=ClassifiedAds_

# Messaging
Messaging__Provider=RabbitMQ
Messaging__RabbitMQ__HostName=YOUR_RENDER_RABBITMQ_HOST
Messaging__RabbitMQ__UserName=YOUR_RABBITMQ_USER
Messaging__RabbitMQ__Password=YOUR_RABBITMQ_PASSWORD
Messaging__RabbitMQ__ExchangeName=amq.direct

# Identity / JWT
Modules__Identity__BootstrapDevelopmentData=false
Modules__Identity__Jwt__SecretKey=REPLACE_WITH_AT_LEAST_32_CHAR_SECRET
Modules__Identity__Jwt__Issuer=https://YOUR_WEBAPI_SERVICE.onrender.com
Modules__Identity__Jwt__Audience=ClassifiedAds.WebAPI
Modules__Identity__Jwt__AccessTokenExpirationMinutes=60
Modules__Identity__Jwt__RefreshTokenExpirationDays=7

# Storage
Modules__Storage__Provider=Local
Modules__Storage__Local__Path=/var/data/storage
Modules__Storage__MasterEncryptionKey=REPLACE_WITH_BASE64_32_BYTE_KEY

# CORS
CORS__AllowAnyOrigin=false
CORS__AllowedOrigins__0=https://YOUR_FRONTEND_DOMAIN

# Notification
Modules__Notification__Email__Provider=Fake
Modules__Notification__Sms__Provider=Fake
Modules__Notification__Web__Provider=Fake
