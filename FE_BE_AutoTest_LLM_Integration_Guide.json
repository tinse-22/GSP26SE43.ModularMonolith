  "checklists": {
    "beforeOrderProposal": [
      "Have a valid projectId.",
      "Have a valid specId.",
      "Do not assume upload completion means parse completion.",
      "Use a specification whose parseStatus is Success.",
      "Load endpoint state from the target specification before creating the suite or proposal."
    ],
    "beforeGeneration": [
      "selectedEndpointIds must belong to the suite specification.",
      "A latest proposal must exist.",
      "The proposal must be approved or modified-and-approved.",
      "GET order-gate-status must report gate passed.",
      "Poll generation-status after receiving a generation job id."
    ],
    "beforeExecution": [
      "Suite must be Ready.",
      "Provide environmentId or ensure a default environment exists.",
      "Do not resend masked environment secrets.",
      "Disable cases or pass selectedTestCaseIds when FE needs a subset run.",
      "Understand that strictValidation defaults to false when omitted."
    ],
    "resultsAndExplanation": [
      "Treat hasDetailedResults as a hint, not a guarantee.",
      "Handle resultsSource=unavailable as a valid FE state.",
      "Use GET explanation for cache-first UX.",
      "Use POST explanation to generate live when needed."
    ]
  },
  "commonPitfalls": [
    "Assuming generate-happy-path and generate-boundary-negative still represent distinct runtime branches in the current default environment.",
    "Assuming the bodies of generate-happy-path or generate-boundary-negative still drive runtime behavior when unified mode is on.",
    "Sending string enum values for AddTestCaseRequest or UpdateTestCaseRequest enum fields even though the current host serializer expects numbers there.",
    "Parsing ExecutionAuthConfigModel.AuthType as a number even though it is returned as a string.",
    "Forgetting rowVersion on suite update, proposal reorder, proposal approve/reject, environment update/delete, or suggestion review.",
    "Sending Modify without modifiedContent.",
    "Sending Reject without reviewNotes.",
    "Treating JSON-string fields as nested objects without parse/stringify handling.",
    "Resending ****** as if it were a real auth secret on environment updates.",
    "Skipping parse-status polling for OpenAPI YAML or Postman uploads.",
    "Skipping generation-status polling while unified generation is enabled.",
    "Expecting GET results to rebuild detailed data from PostgreSQL after cache loss.",
    "Using GET explanation as if it were the live generation endpoint."
  ],
  "uncertainties": [
    "Authorization failure payloads like 401 or 403 may still depend on ASP.NET Core auth pipeline behavior outside the module handlers reviewed here.",
    "Multipart enum binding details for upload requests depend on ASP.NET Core model binding behavior in addition to the request model converters.",
    "Runtime deployments can override appsettings through environment variables, so callback generation mode is the checked-in default rather than a universal guarantee across every environment.",
    "SpecificationDetailModel.OriginalFileName exists on the model but is not populated by the currently verified query path.",
    "The config tree still contains DotnetIntegration naming, while the verified unified generation path currently uses the logical webhook name generate-test-cases-unified.",
    "Manual test-case request enum transport is a serializer-dependent behavior and would change if the host later adds a global JsonStringEnumConverter."
  ],
