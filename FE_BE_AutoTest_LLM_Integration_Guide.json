{
  "meta": {
    "title": "FE/BE Auto Test + LLM Integration Guide",
    "language": "vi-VN",
    "generatedFromSource": true,
    "purpose": "Machine-readable FE integration package for the current backend workflow and API contracts.",
    "scope": [
      "project lifecycle",
      "specification lifecycle",
      "endpoint curation",
      "test suite scope",
      "order proposal and gate",
      "unified test generation",
      "llm suggestion review",
      "manual test-case CRUD",
      "execution environment",
      "test run execution",
      "run results",
      "failure explanation"
    ]
  },
  "checkedInDefaults": {
    "useDotnetIntegrationWorkflowForGeneration": true,
    "generationMode": "callback",
    "canonicalGenerationEntrypoint": "POST /api/test-suites/{suiteId}/generate-tests",
    "equivalentGenerationEntrypointsWhenUnifiedMode": [
      "POST /api/test-suites/{suiteId}/generate-tests",
      "POST /api/test-suites/{suiteId}/test-cases/generate-happy-path",
      "POST /api/test-suites/{suiteId}/test-cases/generate-boundary-negative"
    ],
    "unifiedModeRequestBodyBehavior": "When unified mode is on, generate-happy-path and generate-boundary-negative request bodies are accepted by MVC but are not used to drive the current runtime path; the controller only queues GenerateTestCasesCommand.",
    "generationWebhookName": "generate-test-cases-unified",
    "generationJobObservedLifecycle": [
      "Queued",
      "Triggering",
      "WaitingForCallback",
      "Completed",
      "Failed"
    ],
    "testRunExecutionMode": "synchronous_request_response",
    "publicResultsEndpointFallbackToDatabase": false,
    "failureExplanation": {
      "provider": "N8n",
      "cacheTtlHours": 24,
      "getIsCacheOnly": true,
      "postCanGenerateLive": true
    }
  },
