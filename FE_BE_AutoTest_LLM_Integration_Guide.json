  "workflowModes": {
    "specificationParsing": {
      "uploadOpenApiJson": "inline parse in request",
      "uploadOpenApiYamlOrPostman": "create spec as Pending then parse asynchronously",
      "manualSpecification": "synchronous success",
      "curlImport": "synchronous success"
    },
    "testGeneration": {
      "default": "callback_unified_workflow",
      "legacyAlternative": "sync_happy_path_or_boundary_negative_when_unified_flag_off",
      "requiresApprovedOrderGate": true
    },
    "testExecution": {
      "mode": "synchronous_request_response",
      "detailedResultsStorage": "Redis",
      "summaryStorage": "PostgreSQL"
    },
    "failureExplanation": {
      "get": "cache_only",
      "post": "generate_if_needed_then_cache"
    }
  },
  "workflowAtoZ": [
    {
      "phase": "projectAndSpecificationFoundation",
      "steps": [
        "Create project.",
        "Upload, import, or create specification.",
        "Poll parseStatus when upload mode does not parse inline.",
        "Activate the specification used by the test workflow.",
        "Load endpoint list from the target specification."
      ],
      "blockingRules": [
        "Test suite auto flow requires a valid apiSpecId.",
        "Order proposal and downstream generation depend on endpoints from the same specification."
      ]
    },
    {
      "phase": "endpointCuration",
      "steps": [
        "Optionally create, update, or delete endpoints under the specification.",
        "Use resolved-url and path-param-mutations helpers when FE needs preview or boundary UX support.",
        "Treat the current persisted endpoint state as the source for later order and generation steps."
      ]
    },
    {
      "phase": "testSuiteCreation",
      "steps": [
        "Create a suite with name, apiSpecId, generationType, and selectedEndpointIds.",
        "Optionally provide endpointBusinessContexts and globalBusinessRules.",
        "Use rowVersion for every suite update or delete action."
      ],
      "blockingRules": [
        "Only the suite owner can generate, review suggestions, or run tests.",
        "selectedEndpointIds must belong to the suite specification."
      ]
    },
    {
      "phase": "orderProposalAndGate",
      "steps": [
        "Create an order proposal.",
        "Load the latest proposal.",
        "Allow reorder, approve, or reject.",
        "Check order-gate-status before generation or llm suggestion preview."
      ],
      "blockingRules": [
        "The active proposal must be approved or modified-and-approved.",
        "Applied order must be non-empty."
      ]
    },
    {
      "phase": "unifiedGenerationDefaultFlow",
      "steps": [
        "Call generate-tests or one of the legacy generation endpoints while unified mode is on.",
        "Receive 202 Accepted with a generation job id.",
        "Poll generation-status.",
        "Background triggers n8n webhook generate-test-cases-unified.",
        "n8n posts generated test cases back through the callback endpoint.",
        "Backend replaces suite test cases and marks the suite Ready."
      ],
      "notes": [
        "In current unified mode, the bodies of generate-happy-path and generate-boundary-negative do not drive runtime behavior."
      ]
    },
    {
      "phase": "llmSuggestionPreviewAndReview",
      "steps": [
        "Generate preview suggestions after the order gate passes.",
        "List or load suggestion detail.",
        "Approve, reject, or modify suggestions.",
        "Materialize approved or modified suggestions into real test cases."
      ],
      "blockingRules": [
        "forceRefresh=false is blocked when pending suggestions already exist.",
        "Reject requires reviewNotes.",
        "Modify requires modifiedContent.",
        "Bulk review only supports Approve or Reject."
      ],
      "notes": [
        "Approve can be idempotent when the suggestion was already materialized.",
        "Review service can reuse an existing AppliedTestCaseId when approval fingerprints match."
      ]
    },
    {
      "phase": "manualTestCaseManagement",
      "steps": [
        "Add, update, delete, restore, toggle, reorder, bulk-delete, or bulk-restore test cases.",
        "Use manual CRUD when FE wants explicit control instead of relying on LLM generation."
      ],
      "notes": [
        "DELETE test case returns 200 OK with a TestCaseModel.",
        "toggle and reorder return 200 OK with an empty body."
      ]
    },
    {
      "phase": "executionEnvironmentPreparation",
      "steps": [
        "Create or update an execution environment.",
        "Set one environment as default if FE wants environmentId to be optional at run start.",
        "Provide full secrets again on update when authConfig contains protected values."
      ],
      "blockingRules": [
        "baseUrl must be an absolute http or https URL.",
        "Do not send masked secret placeholders like ****** back to the API as if they were real secrets."
      ]
    },
    {
      "phase": "testRunExecution",
      "steps": [
        "Start a run with an optional environmentId, optional selectedTestCaseIds, and optional strictValidation.",
        "Backend validates ownership, suite Ready state, case eligibility, environment availability, and quota limits.",
        "Runtime resolves variables and auth, then executes cases sequentially.",
        "Detailed results are cached and summary data is persisted."
      ],
      "notes": [
        "strictValidation defaults to false when omitted.",
        "Dependency-failed cases become Skipped."
      ]
    },
    {
      "phase": "resultsAndFailureExplanation",
      "steps": [
        "Load run summaries from the run list or run detail endpoint.",
        "Use GET results for cached detailed data only.",
        "Treat resultsSource=unavailable as a valid state.",
        "Use GET explanation for cache-first UX, then POST explanation to generate live when needed."
      ],
      "notes": [
        "hasDetailedResults is a hint derived from resultsExpireAt and is not a hard guarantee that Redis still contains the payload.",
        "Public GET results does not reconstruct detailed cases from PostgreSQL."
      ]
    }
  ],
