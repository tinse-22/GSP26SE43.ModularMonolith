  "errorContracts": {
    "exceptionProblemDetails": {
      "contentType": "application/problem+json",
      "fields": [
        "type",
        "title",
        "status",
        "detail",
        "message",
        "traceId",
        "reasonCode"
      ],
      "notes": [
        "message is present for exception-driven errors handled by GlobalExceptionHandler.",
        "reasonCode only appears on some conflict, concurrency, or transient branches.",
        "Transient database failures can emit Retry-After: 2 with reasonCode TRANSIENT_NPGSQL_CONNECTION."
      ]
    },
    "validationProblemDetails": {
      "contentType": "application/problem+json",
      "fields": [
        "type",
        "title",
        "status",
        "instance",
        "traceId",
        "errors"
      ],
      "notes": [
        "Validation responses do not use the same top-level message field as exception-driven errors."
      ]
    }
  },
